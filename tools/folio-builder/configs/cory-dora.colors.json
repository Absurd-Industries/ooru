{
  "_comment": "Per-part materials for CoryDora_Fully_Assembled_v1.2.step, granular so the web customizer can isolate front plate / back plate / trim / keycaps / switches / knob. Solids are bucketed by geometry; see tools/step-colorize.mjs. Colours sampled from the shop photo.",
  "tolerance": 0.25,
  "yUp": true,
  "separate": true,
  "fallback": { "name": "interior", "color": "#1B1B1D" },
  "rules": [
    { "name": "backplate", "color": "#E7DCC2", "footprint": "full", "dzMin": 8 },
    { "name": "frontplate", "color": "#E7DCC2", "footprint": "full", "dzMin": 3, "dzMax": 8 },
    { "name": "trim", "color": "#F2851F", "footprint": "full", "dzMax": 3 },
    { "name": "knob", "color": "#F58A21", "dxMin": 12, "dxMax": 20, "dyMin": 12, "dyMax": 20, "zmaxMin": 30 },
    { "name": "keycaps", "color": "#6B4DB3", "dxMin": 17, "dxMax": 20, "dyMin": 17, "dyMax": 20, "dzMin": 6, "dzMax": 11, "zminMin": 20 },
    { "name": "switches", "color": "#1C1C1E", "dxMin": 13, "dxMax": 16, "dyMin": 13, "dyMax": 16, "dzMin": 4, "dzMax": 8, "zminMin": 11, "zminMax": 20 },
    { "name": "pcb", "color": "#18583F", "dxMin": 80, "dyMin": 55, "dzMax": 3 }
  ]
}
