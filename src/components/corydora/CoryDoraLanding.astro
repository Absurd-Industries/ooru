---
/**
 * CoryDora campaign page = the interactive visualizer (story + customizer) up
 * top, then the standard showcase campaign body (same as Supersaber) populated
 * with CoryDora's details. No separate "classic" view - this is the one page.
 */
import GenericCampaign from "../GenericCampaign.astro";
import CoryDoraExperience from "./CoryDoraExperience.vue";
import CoryDoraField from "./CoryDoraField.vue";
import { projects } from "../../data/projects";
import { corydoraLanding as L } from "../../data/corydora-landing";
import type { Campaign } from "../../types";

interface Props {
    campaign: Campaign;
}
const { campaign } = Astro.props;
const project = projects.find((p) => p.slug === L.projectSlug);
const SHOW_FOOTER = false; // footer "sea" - off for a perf test; flip to true to restore
---

<GenericCampaign campaign={campaign}>
    <section slot="top" class="cd-viewer">
        {
            project?.modelUrl ? (
                <CoryDoraExperience
                    src={project.modelUrl}
                    alt={project.title}
                    dimensions={project.modelDimensions}
                    campaignSlug={campaign.slug}
                    tiers={campaign.tiers ?? L.tiers}
                    journey={L.journey}
                    customizeCamMobile={L.customizeCamMobile}
                    files={project.files}
                    specs={project.specs}
                    license={project.license}
                    client:load
                />
            ) : null
        }
    </section>
    {
        SHOW_FOOTER && project?.modelUrl ? (
            <CoryDoraField slot="bottom" src={project.modelUrl} client:visible />
        ) : null
    }
</GenericCampaign>

<style>
    .cd-viewer { background: #12141a; }
</style>
