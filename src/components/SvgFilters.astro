---
/**
 * SVG filter definitions for paper-cut card edges.
 * Rendered once in BaseLayout, hidden via position:absolute.
 * Cards reference these by filter ID: url(#papercut), url(#torn), etc.
 */
---

<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <!-- Hero: strong torn edge -->
  <filter id="torn">
    <feTurbulence type="turbulence" baseFrequency="0.04" numOctaves="5" result="n" />
    <feDisplacementMap in="SourceGraphic" in2="n" scale="5" xChannelSelector="R" yChannelSelector="G" />
  </filter>
  <!-- Cards: subtle paper-cut -->
  <filter id="papercut">
    <feTurbulence type="turbulence" baseFrequency="0.04" numOctaves="4" result="n" />
    <feDisplacementMap in="SourceGraphic" in2="n" scale="3" xChannelSelector="R" yChannelSelector="G" />
  </filter>
  <filter id="papercut-2">
    <feTurbulence type="turbulence" baseFrequency="0.035" numOctaves="4" seed="3" result="n" />
    <feDisplacementMap in="SourceGraphic" in2="n" scale="3" xChannelSelector="R" yChannelSelector="G" />
  </filter>
  <filter id="papercut-3">
    <feTurbulence type="turbulence" baseFrequency="0.045" numOctaves="4" seed="7" result="n" />
    <feDisplacementMap in="SourceGraphic" in2="n" scale="3.5" xChannelSelector="R" yChannelSelector="G" />
  </filter>
  <!-- Profile/avatar octagon with softly rounded corners (scales to any square element) -->
  <clipPath id="rounded-octagon" clipPathUnits="objectBoundingBox">
    <path d="M0.364,0 L0.636,0 Q0.7,0 0.748,0.048 L0.952,0.252 Q1,0.3 1,0.364 L1,0.636 Q1,0.7 0.952,0.748 L0.748,0.952 Q0.7,1 0.636,1 L0.364,1 Q0.3,1 0.252,0.952 L0.048,0.748 Q0,0.7 0,0.636 L0,0.364 Q0,0.3 0.048,0.252 L0.252,0.048 Q0.3,0 0.364,0 Z" />
  </clipPath>
</svg>
