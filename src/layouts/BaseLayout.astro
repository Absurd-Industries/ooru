---
/**
 * Base layout for all platform pages.
 * Includes: head (fonts, icons, meta), SVG filters, wonky logo, footer, bottom bar.
 * Every page wraps its content in this layout and only needs to provide the unique body.
 */

import { ClientRouter } from "astro:transitions";
import SvgFilters from "../components/SvgFilters.astro";
import Footer from "../components/Footer.astro";
import TopNav from "../components/TopNav.vue";
import BottomBar from "../components/BottomBar.vue";
import ComingSoon from "../components/ComingSoon.vue";
import WelcomeModal from "../components/WelcomeModal.vue";
import DebugPanel from "../components/DebugPanel.vue";
import I18n from "../components/I18n.astro";
import "../styles/global.css";

const isDev = import.meta.env.DEV;

interface Props {
    /** Page title - appended with "| Ooru" */
    title: string;
    /** Meta description for SEO */
    description?: string;
    /** OG/Twitter card image (path or absolute URL). 1200x630 recommended. */
    ogImage?: string;
    /** Alt text for the OG image */
    ogImageAlt?: string;
    /** Open Graph type: "website" | "article" | "profile" etc. */
    ogType?: string;
    /** Comma-separated keywords for the meta keywords tag */
    keywords?: string;
    /** Exclude this page from search engines */
    noindex?: boolean;
    /** Page-specific JSON-LD structured data (object or array) */
    jsonLd?: Record<string, unknown> | Record<string, unknown>[];
    /** Which bottom bar tab is active: "campaigns", "makers", "requests", "events" */
    activeTab?: string;
    /** Enable dark mode (class="dark" on html) - used by inventory */
    darkMode?: boolean;
    /** Hide bottom/desktop nav - used on immersive pages like campaign detail */
    hideNav?: boolean;
}

const {
    title,
    description = "Ooru is where people build open hardware and share exactly how it's made. Back projects, discover makers, request what you need, and build together.",
    ogImage = "/og/default.png",
    ogImageAlt,
    ogType = "website",
    keywords,
    noindex = false,
    jsonLd,
    activeTab,
    darkMode = false,
    hideNav = false,
} = Astro.props;

const fullTitle = `${title} | Ooru`;
const SITE = Astro.site ?? new URL("https://ooru.build");
const canonicalUrl = new URL(Astro.url.pathname, SITE);
const ogImageUrl = new URL(ogImage, SITE);
const ogAlt = ogImageAlt ?? `${title} - Ooru`;

// Site-wide structured data (Organization + WebSite), present on every page.
const orgLd = {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Ooru",
    url: SITE.href,
    logo: new URL("/og/default.png", SITE).href,
    description:
        "Your community for open-source hardware. India-rooted, globally open.",
    sameAs: [
        "https://discord.gg/DUSUtguG2H",
        "https://www.instagram.com/absurd.science",
        "https://x.com/absurdit_y",
        "https://www.youtube.com/@absurd.industries",
        "https://in.linkedin.com/company/absurd-explorations",
    ],
};
const siteLd = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Ooru",
    url: SITE.href,
};
const jsonLdBlocks = [
    orgLd,
    siteLd,
    ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []),
];
---

<!doctype html>
<html lang="en" class:list={[{ dark: darkMode }]}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="color-scheme" content={darkMode ? "light dark" : "light"} />
        <meta name="theme-color" content="#D4B896" />
        <title>{fullTitle}</title>
        <meta name="description" content={description} />
        {keywords && <meta name="keywords" content={keywords} />}
        <meta name="author" content="Ooru" />
        <meta
            name="robots"
            content={noindex ? "noindex, nofollow" : "index, follow"}
        />
        <link rel="canonical" href={canonicalUrl} />

        <!-- Open Graph -->
        <meta property="og:site_name" content="Ooru" />
        <meta property="og:type" content={ogType} />
        <meta property="og:title" content={fullTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:image" content={ogImageUrl} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={ogAlt} />
        <meta property="og:locale" content="en_IN" />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={fullTitle} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageUrl} />
        <meta name="twitter:image:alt" content={ogAlt} />

        <!-- Structured data -->
        {
            jsonLdBlocks.map((block) => (
                <script
                    type="application/ld+json"
                    set:html={JSON.stringify(block)}
                />
            ))
        }

        <!-- Favicon -->
        <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/favicon/apple-touch-icon.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href="/favicon/favicon-32x32.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="16x16"
            href="/favicon/favicon-16x16.png"
        />
        <link rel="shortcut icon" href="/favicon/favicon.ico" />

        <!-- Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Montserrat:wght@900&family=Noto+Sans+Kannada:wght@400;700;800&family=Noto+Sans+Telugu:wght@400;700;800&display=swap"
            rel="stylesheet"
        />

        <!-- Icons: Phosphor (CSS only - bold + duotone weights used) -->
        <link
            rel="stylesheet"
            href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/bold/style.css"
        />
        <link
            rel="stylesheet"
            href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/duotone/style.css"
        />
        <link
            rel="stylesheet"
            href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/fill/style.css"
        />

        <!-- Icons: FontAwesome brands (CSS webfont - no JS, survives view transitions) -->
        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/brands.min.css"
            integrity="sha512-8RxmFOVaKQe/xtg6lbscU9DU0IRhURWEuiI0tXevv+lXbAHfkpamD4VKFQRto9WgfOJDwOZ74c/s9Yesv3VvIQ=="
            crossorigin="anonymous"
            referrerpolicy="no-referrer"
        />
        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/fontawesome.min.css"
            integrity="sha512-d0olNN35C6VLiulAobxYHZiXJmq+vl+BGIgAxQtD5+kqudro/xNMvv2yIHAciGHpExTmF6XHQZFpKBtLW5csw=="
            crossorigin="anonymous"
            referrerpolicy="no-referrer"
        />

        <I18n />

        <ClientRouter />
    </head>

    <body class="font-sans text-ink min-h-screen antialiased pb-0">
        <div class="design-preview-bar" role="note">
            <i class="ph-bold ph-warning-circle"></i>
            <span
                >Design preview - Everything on this page is a placeholder</span
            >
        </div>
        <SvgFilters />
        <ComingSoon client:load />
        <WelcomeModal client:load />

        {!hideNav && <TopNav activeTab={activeTab} client:load />}

        <slot />

        {!hideNav && <Footer />}
        {!hideNav && <BottomBar activeTab={activeTab} client:load />}
        {
            isDev && (
                <DebugPanel
                    route={Astro.url.pathname}
                    renderMode="static"
                    pageTitle={title}
                    client:idle
                />
            )
        }
    </body>
</html>
