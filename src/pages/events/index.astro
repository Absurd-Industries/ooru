---
/**
 * Events listing page.
 * Shows Bengaluru-first STEAM events - meetups, workshops, hackathons,
 * talks, and conferences. Calendar/planner view with city filtering
 * and search, handled client-side by the EventsListing Vue island.
 */

import BaseLayout from "../../layouts/BaseLayout.astro";
import { t } from "../../i18n";
import EventsListing from "../../components/EventsListing.vue";
import { events } from "../../data/events";
---

<BaseLayout
  title="Events"
  description="Bengaluru-first STEAM events - meetups, workshops, hackathons, talks, and conferences for makers, scientists, artists, and engineers."
  ogImage="/og/events.png"
  activeTab="events"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-6 pb-8 md:pt-8 md:pb-12">
    <!-- Page Header -->
    <div class="mb-6">
      <h1 class="font-serif text-3xl sm:text-4xl font-bold tracking-tight text-ink mb-2">
        <i class="ph-duotone ph-calendar-dots text-ink mr-2" style="font-size:1.4rem;"></i><span data-i18n="section.events">{t("section.events")}</span>
      </h1>
      <p class="text-sm text-ink max-w-lg leading-relaxed" data-i18n="page.events.desc">
        {t("page.events.desc")}
      </p>
    </div>

    <!-- Interactive calendar listing island -->
    <EventsListing events={events} client:load />
  </div>
</BaseLayout>
