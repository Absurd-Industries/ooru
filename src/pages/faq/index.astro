---
/**
 * FAQ page.
 * Accordion-style frequently asked questions using native <details>/<summary>.
 * Each question has a topic icon, matching the homepage teaser style.
 */

import BaseLayout from "../../layouts/BaseLayout.astro";
import { t } from "../../i18n";
import Card from "../../components/Card.astro";
---

<BaseLayout
  title="FAQ"
  description="Frequently asked questions about Ooru, campaigns, requests, open-source licensing, and the maker community."
  ogImage="/og/faq.jpg"
  activeTab="faq"
>
  <!-- Header on kraft background -->
  <div class="max-w-4xl mx-auto px-5 sm:px-6 pt-6 pb-6">
    <div class="mb-2">
      <h1 class="font-serif text-3xl sm:text-4xl font-bold tracking-tight text-ink mb-2">
        <i class="ph-duotone ph-question text-ink mr-2" style="font-size:1.4rem;"></i><span data-i18n="section.faq">{t("section.faq")}</span>
      </h1>
      <p class="text-sm text-ink max-w-lg leading-relaxed" style="font-weight:450;" data-i18n="page.faq.desc">
        {t("page.faq.desc")}
      </p>
    </div>
  </div>

  <!-- FAQ accordion inside a Card -->
  <section class="pb-16 sm:pb-20">
    <div class="max-w-4xl mx-auto px-5 sm:px-6">
      <Card>
        <div class="faq-list" id="faq-accordion">

          <details name="ooru-faq">
            <summary>
              <i class="ph-duotone ph-question faq-q-icon"></i>
              <span data-i18n="faq.q1">{t("faq.q1")}</span>
              <i class="ph-bold ph-caret-down faq-icon"></i>
            </summary>
            <div class="faq-answer" data-i18n="faq.a1">{t("faq.a1")}</div>
          </details>

          <details name="ooru-faq">
            <summary>
              <i class="ph-duotone ph-rocket-launch faq-q-icon"></i>
              <span data-i18n="faq.q2">{t("faq.q2")}</span>
              <i class="ph-bold ph-caret-down faq-icon"></i>
            </summary>
            <div class="faq-answer" data-i18n="faq.a2">{t("faq.a2")}</div>
          </details>

          <details name="ooru-faq">
            <summary>
              <i class="ph-duotone ph-hand-palm faq-q-icon"></i>
              <span data-i18n="faq.q3">{t("faq.q3")}</span>
              <i class="ph-bold ph-caret-down faq-icon"></i>
            </summary>
            <div class="faq-answer" data-i18n="faq.a3">{t("faq.a3")}</div>
          </details>

          <details name="ooru-faq">
            <summary>
              <i class="ph-duotone ph-scales faq-q-icon"></i>
              <span data-i18n="faq.q4">{t("faq.q4")}</span>
              <i class="ph-bold ph-caret-down faq-icon"></i>
            </summary>
            <div class="faq-answer" data-i18n="faq.a4">{t("faq.a4")}</div>
          </details>

          <details name="ooru-faq">
            <summary>
              <i class="ph-duotone ph-users-three faq-q-icon"></i>
              <span data-i18n="faq.q5">{t("faq.q5")}</span>
              <i class="ph-bold ph-caret-down faq-icon"></i>
            </summary>
            <div class="faq-answer" data-i18n="faq.a5">{t("faq.a5")}</div>
          </details>

          <details name="ooru-faq">
            <summary>
              <i class="ph-duotone ph-megaphone faq-q-icon"></i>
              <span data-i18n="faq.q6">{t("faq.q6")}</span>
              <i class="ph-bold ph-caret-down faq-icon"></i>
            </summary>
            <div class="faq-answer" data-i18n="faq.a6">{t("faq.a6")}</div>
          </details>

          <details name="ooru-faq">
            <summary>
              <i class="ph-duotone ph-map-pin faq-q-icon"></i>
              <span data-i18n="faq.q7">{t("faq.q7")}</span>
              <i class="ph-bold ph-caret-down faq-icon"></i>
            </summary>
            <div class="faq-answer" data-i18n="faq.a7">{t("faq.a7")}</div>
          </details>

          <details name="ooru-faq">
            <summary>
              <i class="ph-duotone ph-coin faq-q-icon"></i>
              <span data-i18n="faq.q8">{t("faq.q8")}</span>
              <i class="ph-bold ph-caret-down faq-icon"></i>
            </summary>
            <div class="faq-answer" data-i18n="faq.a8">{t("faq.a8")}</div>
          </details>

        </div>
      </Card>
    </div>
  </section>

  <style>
    details {
      border-bottom: 1px solid rgba(26, 26, 26, 0.08);
    }
    details:last-child {
      border-bottom: none;
    }
    summary {
      font-family: 'Fraunces', serif;
      font-weight: 700;
      font-size: 1rem;
      color: #1A1A1A;
      cursor: pointer;
      list-style: none;
      display: flex;
      align-items: center;
      gap: 0.65rem;
      padding: 1.25rem 1.5rem;
      transition: color 0.15s;
    }
    summary::-webkit-details-marker { display: none; }
    summary:hover { color: #FF5900; }
    /* Open state stays ink - orange is reserved for hover/interaction */
    details[open] summary { color: #1A1A1A; }
    summary span {
      flex: 1;
    }
    .faq-q-icon {
      font-size: 1.1rem;
      flex-shrink: 0;
      color: #6B5B4A;
      transition: color 0.15s;
    }
    details[open] .faq-q-icon {
      color: #6B5B4A;
    }
    summary:hover .faq-q-icon {
      color: #FF5900;
    }
    .faq-icon {
      transition: transform 0.2s ease;
      flex-shrink: 0;
      font-size: 0.85rem;
      color: #6B5B4A;
    }
    details[open] .faq-icon {
      transform: rotate(180deg);
      color: #6B5B4A;
    }
    .faq-list {
      background: rgba(250, 243, 232, 0.6);
      border-radius: 0.75rem;
    }
    .faq-answer {
      font-size: 0.9rem;
      color: #4A3D2F;
      line-height: 1.7;
      padding: 0 1.5rem 1.25rem 3.25rem;
    }
  </style>

  <script is:inline>
  (function() {
    var accordion = document.getElementById('faq-accordion');
    if (!accordion) return;
    accordion.addEventListener('click', function(e) {
      var summary = e.target.closest('summary');
      if (!summary) return;
      var parent = summary.parentElement;
      accordion.querySelectorAll('details[open]').forEach(function(d) {
        if (d !== parent) d.removeAttribute('open');
      });
    });
  })();
  </script>
</BaseLayout>
