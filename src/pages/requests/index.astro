---
/**
 * Requests listing page.
 * Displays a searchable, filterable, sortable feed of community requests.
 * Top section (header) sits on the kraft background, feed items sit on warm cream.
 */

import BaseLayout from "../../layouts/BaseLayout.astro";
import { t } from "../../i18n";
import RequestsListing from "../../components/RequestsListing.vue";
import { requests } from "../../data/requests";
import { makers } from "../../data/makers";

// Build a slug -> display name map for claimed-by lookups
const makerNames: Record<string, string> = {};
for (const m of makers) {
  makerNames[m.slug] = m.name;
}
---

<BaseLayout
  title="Requests"
  description="Request open-source projects that don't exist yet. Describe what you need, refine specs together, and let makers bring it to life."
  ogImage="/og/requests.png"
  activeTab="requests"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-6 pb-4">
    <!-- Page header (on kraft background) -->
    <div class="mb-6">
      <h1 class="font-serif text-3xl sm:text-4xl font-bold tracking-tight text-ink mb-2">
        <i class="ph-duotone ph-hand-palm text-ink mr-2" style="font-size:1.4rem;"></i><span data-i18n="section.requests">{t("section.requests")}</span>
      </h1>
      <p class="text-sm text-ink max-w-lg leading-relaxed" data-i18n="page.requests.desc">
        {t("page.requests.desc")}
      </p>
    </div>
  </div>

  <!-- Cream paper section for the feed -->
  <div class="requests-feed-bg">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-8 pb-12">
      <RequestsListing
        requests={requests}
        makerNames={makerNames}
        client:load
      />
    </div>
  </div>

  <style>
    .requests-feed-bg {
      /* Warm cream over the kraft body (matches the cards / events / FAQ) */
      background-color: rgba(250, 243, 232, 0.6);
      min-height: 60vh;
    }
  </style>
</BaseLayout>
