                                                    target="_blank"
                                                    rel="noopener"
                                                    class="side-link"
                                                >
                                                    <i
                                                        class:list={[
                                                            "side-link-icon",
                                                            link.iconType ===
                                                                "github" &&
                                                                "ph-bold ph-github-logo",
                                                            link.iconType ===
                                                                "globe" &&
                                                                "ph-bold ph-globe",
                                                            link.iconType ===
                                                                "twitter" &&
                                                                "ph-bold ph-x-logo",
                                                        ]}
                                                    />
                                                    <span class="flex-1 min-w-0 truncate">
                                                        {link.label}
                                                    </span>
                                                    <i class="ph-bold ph-arrow-square-out text-xs text-ink-faint flex-shrink-0" />
                                                </a>
                                            ))}
                                        </div>
                                    </div>
                                </Card>
                            )
                        }
                    </div>
                </div>
            </div>
