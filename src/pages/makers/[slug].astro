---
/**
 * Steam-style maker profile detail page.
 * Generated at build time from the makers data via getStaticPaths().
 *
 * Layout: profile banner, two-column body (main + sidebar), with
 * showcase, activity feed, projects grid, workshop section,
 * comment wall, badges, skills, and about panels.
 */

import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/Card.astro";
import Tag from "../../components/Tag.astro";
import ProgressBar from "../../components/ProgressBar.astro";
import CheerButton from "../../components/CheerButton.vue";
import CampaignDiscussion from "../../components/CampaignDiscussion.vue";
import { makers } from "../../data/makers";
import type { Maker } from "../../types";

export function getStaticPaths() {
    return makers.map((maker) => ({
        params: { slug: maker.slug },
        props: { maker },
    }));
}

const { maker } = Astro.props as { maker: Maker };

// ────────────────────────────────────────────────────────────
// Per-maker enriched data (mock / derived for static build)
// In production these would come from the API.
// ────────────────────────────────────────────────────────────

/** Banner colour - use avatarColor as the default */
const bannerColor = maker.avatarColor;
const bannerAccent = "#FF5900";

const initial = maker.name.charAt(0).toUpperCase();
const firstName = maker.name.split(" ")[0];

/** Showcase - first project (mock campaign data) */
const showcase = {
    name: `${firstName}'s Featured Project`,
    description:
        maker.bio ??
        `Open-source ${maker.specialty.toLowerCase()} project by ${maker.name}.`,
    icon: getSpecialtyIcon(maker.specialty),
    category: maker.specialty,
    license: "CERN-OHL-S",
    percent: Math.min(
        Math.round((maker.backers / (maker.backers + 50)) * 100),
        100,
    ),
    goal: `₹${Math.round((maker.backers * 1400) / 100000).toFixed(0)},00,000`,
    backers: maker.backers,
    link: "/campaigns",
};

function getSpecialtyIcon(specialty: string): string {
    const map: Record<string, string> = {
        Electronics: "cpu",
        Firmware: "code",
        "Product Design": "cube",
        Education: "graduation-cap",
        Robotics: "robot",
        Audio: "speaker-high",
    };
    return map[specialty] ?? "wrench";
}

/** Activity feed entries */
const activities = [
    {
        icon: "rocket-launch",
        text: `Launched <strong>${showcase.name}</strong> campaign`,
        time: "3 days ago",
        highlight: true,
        miniCard: {
            icon: showcase.icon,
            name: showcase.name,
            percent: showcase.percent,
            backers: showcase.backers,
        },
    },
    {
        icon: "article",
        text: `Published build journal: <strong>Field Testing v${maker.projects}</strong>`,
        time: "1 week ago",
        highlight: false,
        miniCard: null as null | {
            icon: string;
            name: string;
            percent: number;
            backers: number;
        },
    },
    {
        icon: "file-text",
        text: `Contributed specs to a <span class="text-stamp font-semibold">Community Request</span>`,
        time: "2 weeks ago",
        highlight: false,
        miniCard: null as null | {
            icon: string;
            name: string;
            percent: number;
            backers: number;
        },
    },
    {
        icon: "heart",
        text: "Backed <strong>Desktop CNC Mill</strong> by Vikram Rao",
        time: "3 weeks ago",
        highlight: false,
        miniCard: null as null | {
            icon: string;
            name: string;
            percent: number;
            backers: number;
        },
    },
    {
        icon: "trophy",
        text: `Earned badge: <strong>${maker.backers >= 100 ? "Crowd Favourite" : "First Backer"}</strong>`,
        time: "1 month ago",
        highlight: true,
        miniCard: null as null | {
            icon: string;
            name: string;
            percent: number;
            backers: number;
        },
    },
    {
        icon: "user-plus",
        text: "Joined <strong>Ooru</strong>",
        time: "2024",
        highlight: false,
        miniCard: null as null | {
            icon: string;
            name: string;
            percent: number;
            backers: number;
        },
    },
];

/** Projects list */
const projects = [
    {
        name: showcase.name,
        description: showcase.description,
        icon: showcase.icon,
        status: "Live" as const,
        percent: showcase.percent,
        backers: showcase.backers,
    },
    ...(maker.projects > 1
        ? [
              {
                  name: `${maker.skills[0]} Monitor`,
                  description: `Open-source ${maker.skills[0].toLowerCase()} monitoring system with wireless alerts.`,
                  icon: "chart-line",
                  status: "Completed" as const,
                  percent: 100,
                  backers: Math.round(maker.backers * 0.4),
              },
          ]
        : []),
    ...(maker.projects > 2
        ? [
              {
                  name: `${maker.skills[1] ?? maker.specialty} Kit`,
                  description: `Upcoming kit for ${maker.specialty.toLowerCase()} enthusiasts.`,
                  icon: "package",
                  status: "Coming Soon" as const,
                  percent: null as number | null,
                  backers: 0,
              },
          ]
        : []),
];

/** Badges */
const badges = [
    {
        name: "Guild Member",
        icon: "seal-check",
        description: "Verified Ooru maker",
        bg: "rgba(42,95,65,0.12)",
        color: "#2A5F41",
    },
    {
        name: "First Campaign",
        icon: "flag-banner",
        description: "Successfully funded their first campaign",
        bg: "rgba(255,89,0,0.1)",
        color: "#FF5900",
    },
    ...(maker.backers >= 100
        ? [
              {
                  name: "Crowd Favourite",
                  icon: "users-three",
                  description: "Projects loved by the community",
                  bg: "rgba(26,26,26,0.08)",
                  color: "#1A1A1A",
              },
          ]
        : []),
    {
        name: "Community Helper",
        icon: "handshake",
        description: "Contributed to community requests",
        bg: "rgba(42,95,65,0.12)",
        color: "#2A5F41",
    },
    {
        name: `${maker.specialty} Specialist`,
        icon: "lightning",
        description: `Specialist in ${maker.specialty}`,
        bg: "rgba(107,91,74,0.12)",
        color: "#6B5B4A",
    },
    {
        name: "Open Source",
        icon: "lock-key-open",
        description: "All projects use open-source licenses",
        bg: "rgba(255,89,0,0.1)",
        color: "#FF5900",
    },
];

/** Workshop / Setup */
const workshop = {
    name: `${firstName}'s Workshop`,
    location: maker.location,
    size: "Home workshop",
    hours: "Open for visits by appointment",
    equipment: [
        { name: "3D Printer", icon: "cube" },
        { name: "Soldering Station", icon: "fire" },
        { name: "Oscilloscope", icon: "wave-sine" },
        { name: "Multimeter", icon: "lightning" },
        { name: "Power Supply", icon: "battery-charging" },
        { name: "Hot Air Station", icon: "wind" },
    ],
};

/** Comments wall */
const comments = [
    {
        id: 1,
        author: "Vikram Rao",
        time: "2 days ago",
        text: `${firstName}'s documentation is incredible. This is what open source should look like.`,
    },
    {
        id: 2,
        author: "Arjun Nair",
        time: "1 week ago",
        text: `Thanks for the detailed specs! Your ${maker.skills[0]} recommendations were exactly what we needed.`,
    },
    {
        id: 3,
        author: "Community Member",
        time: "3 weeks ago",
        text: `Exceptional work on the ${maker.specialty.toLowerCase()} projects. Keep shipping!`,
    },
];

/** External links with icons */
const externalLinks = [
    ...(maker.links?.github
        ? [
              {
                  label: maker.links.github.replace("https://", ""),
                  url: maker.links.github,
                  iconType: "github" as const,
              },
          ]
        : []),
    ...(maker.links?.website
        ? [
              {
                  label: maker.links.website.replace("https://", ""),
                  url: maker.links.website,
                  iconType: "globe" as const,
              },
          ]
        : []),
    ...(maker.links?.twitter
        ? [
              {
                  label: maker.links.twitter.replace(
                      "https://twitter.com/",
                      "@",
                  ),
                  url: maker.links.twitter,
                  iconType: "twitter" as const,
              },
          ]
        : []),
];

/** Contribution count (mock) */
const contributions = Math.round(maker.projects * 8 + maker.backers / 10);

// ── Maker Sheet data (no levels/bars - activity heatmap + skill cloud) ──
const baseCheers = 12 + (maker.backers % 50);

// Skill cloud: each skill weighted 1-5 (drives size/emphasis), free-flowing.
const skillCloud = maker.skills.map((skill, i) => ({
    name: skill,
    weight: 1 + ((skill.length + i * 3 + maker.projects) % 5), // 1-5
}));

// (Activity grid + stat tiles removed - the sheet leans on the skill
// cloud + achievements now.)

// Wall comments mapped to the Discussion island's seed shape.
const wallSeed = comments.map((c, i) => ({
    id: c.id,
    author: c.author,
    initials: c.author
        .split(" ")
        .map((w) => w[0])
        .join("")
        .slice(0, 2)
        .toUpperCase(),
    color: ["#2B4C7E", "#B74803", "#2A5F41"][i % 3],
    badge: null,
    badgeVariant: "default",
    time: c.time,
    content: c.text,
    hearts: [5, 3, 7][i] ?? 2,
}));
---

<BaseLayout
    title={`${maker.name} - ${maker.title}`}
    description={maker.bio ??
        `${maker.name} is a ${maker.title} from ${maker.location} on Ooru.`}
    activeTab="makers"
    hideNav
>
    <section class="pt-6 pb-0 sm:pt-8">
        <div class="max-w-5xl mx-auto px-5 sm:px-6">
            <div class="flex items-center justify-between">
                <a href="/makers" class="back-btn">
                    <i class="ph-bold ph-arrow-left"></i>
                    Makers
                </a>
                <button
                    class="share-float-btn"
                    title="Share"
                    onclick="if(navigator.share){navigator.share({title:document.title,url:window.location.href})}else{navigator.clipboard.writeText(window.location.href).then(function(){var i=event.currentTarget.querySelector('i');i.className='ph-bold ph-check';setTimeout(function(){i.className='ph-bold ph-share-network'},1500)})}"
                >
                    <i class="ph-bold ph-share-network"></i>
                </button>
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════ -->
    <!-- PROFILE BANNER                        -->
    <!-- ══════════════════════════════════════ -->
    <section class="pt-4 pb-0" id="about">
        <div class="max-w-5xl mx-auto px-5 sm:px-6">
            <Card>
                <div
                    class="profile-head"
                    style={`--maker: ${bannerColor};`}
                    data-configurable="banner"
                >
                    <div class="punch-hole"></div>
                    <div class="banner-layout">
                        <!-- Octagon Avatar -->
                        <div class="flex-shrink-0">
                            <div class="oct-avatar">
                                {
                                    maker.avatar ? (
                                        <img
                                            src={maker.avatar}
                                            alt={maker.name}
                                            class="oct-avatar-img"
                                        />
                                    ) : (
                                        <span class="font-serif font-bold text-4xl sm:text-5xl text-stencil select-none">
                                            {initial}
                                        </span>
                                    )
                                }
                            </div>
                        </div>

                        <!-- Name + info -->
                        <div class="banner-name-section">
                            <h1
                                class="font-serif font-bold text-xl sm:text-2xl md:text-3xl text-ink tracking-tight leading-tight"
                            >
                                {maker.name}
                            </h1>
                            <div
                                class="flex flex-wrap items-center gap-2 mt-2 text-xs text-stencil"
                            >
                                <span class="flex items-center gap-1"
                                    ><i class="ph-bold ph-map-pin text-xs"></i>{
                                        maker.location
                                    }</span
                                >
                                <span class="profile-specialty"
                                    >{maker.specialty}</span
                                >
                                <span>·</span>
                                <span>{maker.title}</span>
                            </div>
                        </div>

                        <!-- Engagement -->
                        <div class="banner-actions">
                            <CheerButton
                                makerId={maker.slug}
                                baseCount={baseCheers}
                                client:load
                            />
                            <button
                                class="btn btn-outline btn-sm"
                                onclick="window.__comingSoon && window.__comingSoon('Direct Messages', 'Send a private message to this maker. Messaging launches with the next platform update.')"
                            >
                                <i
                                    class="ph-bold ph-envelope-simple mr-1.5"
                                    style="font-size:0.75rem;"></i>
                                Message
                            </button>
                        </div>
                    </div>

                    <!-- Bio -->
                    <p
                        class="text-sm text-ink-light leading-relaxed mt-4 pt-4 profile-bio"
                    >
                        {
                            maker.bio ??
                                `${maker.name} is a ${maker.title} based in ${maker.location}.`
                        }
                    </p>
                </div>
            </Card>
        </div>
    </section>

    <!-- ══════════════════════════════════════ -->
    <!-- TWO-COLUMN LAYOUT                     -->
    <!-- ══════════════════════════════════════ -->
    <section class="pt-6 sm:pt-8 pb-14 md:pb-20">
        <div class="max-w-5xl mx-auto px-5 sm:px-6">
            <div class="flex flex-col lg:flex-row gap-6">
                <!-- ══════════════════════════ -->
                <!-- MAIN COLUMN (LEFT)         -->
                <!-- ══════════════════════════ -->
                <div class="flex-1 min-w-0">
                    <Card>
                        <!-- ── MAKER SHEET (skills + achievements, character-sheet style) ── -->
                        <div
                            id="overview"
                            class="profile-section profile-section--sheet"
                            style={`--maker: ${maker.avatarColor};`}
                            data-configurable="sheet"
                        >
                            <div class="sheet-head">
                                <div class="min-w-0">
                                    <div class="sheet-class">
                                        {maker.specialty}
                                    </div>
                                    <div class="sheet-title-line">
                                        {maker.title}
                                    </div>
                                </div>
                            </div>

                            <!-- Skills (free-flowing cloud, weighted by emphasis) -->
                            <div class="sheet-block">
                                <div class="sheet-block-label">
                                    Skills &amp; Interests
                                </div>
                                <div class="skill-cloud">
                                    {
                                        skillCloud.map((s) => (
                                            <span
                                                class={`skill-chip skill-w${s.weight}`}
                                            >
                                                {s.name}
                                            </span>
                                        ))
                                    }
                                </div>
                            </div>

                            <!-- Achievements -->
                            <div class="sheet-block">
                                <div class="sheet-block-label">
                                    Achievements <span class="sheet-block-count"
                                        >{badges.length}</span
                                    >
                                </div>
                                <div class="flex flex-wrap gap-1.5">
                                    {
                                        badges.map((b) => (
                                            <div
                                                class="achievement"
                                                title={b.description}
                                            >
                                                <i
                                                    class={`ph-bold ph-${b.icon}`}
                                                />
                                                <span>{b.name}</span>
                                            </div>
                                        ))
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- ── SETUP ── -->
                        <div
                            id="setup"
                            class="profile-section profile-section--dark"
                        >
                            <div class="text-paper">
                                <div class="flex items-center gap-3 mb-5">
                                    <i
                                        class="ph-bold ph-wrench text-stamp text-xl"
                                    ></i>
                                    <h2
                                        class="font-serif font-bold text-xl sm:text-2xl tracking-tight"
                                    >
                                        Setup
                                    </h2>
                                </div>

                                <!-- Workspace photos -->
                                <div class="mb-5">
                                    <div class="grid grid-cols-3 gap-2">
                                        <div
                                            class="aspect-video rounded-lg overflow-hidden"
                                        >
                                            <img
                                                src="/images/projects/workdesk.jpg"
                                                alt="Workshop"
                                                class="w-full h-full object-cover"
                                                loading="lazy"
                                            />
                                        </div>
                                        <div
                                            class="aspect-video rounded-lg overflow-hidden"
                                        >
                                            <img
                                                src="/images/projects/workdesk-ii.jpg"
                                                alt="Workspace"
                                                class="w-full h-full object-cover"
                                                loading="lazy"
                                            />
                                        </div>
                                        <div
                                            class="aspect-video rounded-lg overflow-hidden"
                                        >
                                            <img
                                                src="/images/projects/drone-on-cutting-mat.jpg"
                                                alt="Project in progress"
                                                class="w-full h-full object-cover"
                                                loading="lazy"
                                            />
                                        </div>
                                    </div>
                                </div>

                                <!-- Equipment grid -->
                                <div class="mb-5 pt-5 border-t border-paper/10">
                                    <div
                                        class="text-xs font-semibold uppercase tracking-wider text-kraft-dark mb-3"
                                    >
                                        Equipment
                                    </div>
                                    <div
                                        class="grid grid-cols-2 sm:grid-cols-3 gap-2"
                                    >
                                        {
                                            workshop.equipment.map((e) => (
                                                <div
                                                    class="flex items-center gap-2 p-2 rounded-lg"
                                                    style="background:rgba(250,243,232,0.06);"
                                                >
                                                    <div
                                                        class="equip-icon"
                                                        style="width:28px; height:28px; font-size:0.85rem;"
                                                    >
                                                        <i
                                                            class={`ph-bold ph-${e.icon}`}
                                                        />
                                                    </div>
                                                    <span class="text-[0.65rem] text-kraft leading-tight">
                                                        {e.name}
                                                    </span>
                                                </div>
                                            ))
                                        }
                                    </div>
                                </div>

                                <button
                                    onclick="window.__comingSoon && window.__comingSoon('Lab Inventory', 'Browse the full equipment list and specs for this maker\'s workshop. Inventory pages are coming soon.')"
                                    class="flex items-center gap-2 text-sm font-semibold text-stamp hover:underline cursor-pointer bg-transparent border-none p-0"
                                >
                                    <i class="ph-bold ph-package text-sm"></i>
                                    View full lab inventory
                                    <i class="ph-bold ph-arrow-right text-xs"
                                    ></i>
                                </button>
                            </div>
                        </div>

                        <!-- ── ALL PROJECTS ── -->
                        <div id="projects" class="profile-section">
                            <h2
                                class="font-serif font-bold text-xl sm:text-2xl tracking-tight mb-5"
                            >
                                Projects
                            </h2>

                            <div class="space-y-3">
                                {
                                    projects.map((project, idx) => (
                                        <a
                                            href="/campaigns"
                                            class:list={[
                                                "project-card group",
                                                idx === 0 &&
                                                    "project-card--featured",
                                            ]}
                                        >
                                            {idx === 0 && (
                                                <div class="project-featured-label">
                                                    <i
                                                        class="ph-bold ph-star"
                                                        style="font-size:0.55rem;"
                                                    />
                                                    Featured
                                                </div>
                                            )}
                                            <div class="flex items-center gap-3 mb-2">
                                                <div class="w-10 h-10 rounded-lg bg-kraft-light flex items-center justify-center flex-shrink-0">
                                                    <i
                                                        class={`ph-bold ph-${project.icon} text-lg text-stencil group-hover:text-stamp transition-colors`}
                                                    />
                                                </div>
                                                <div class="flex-1 min-w-0">
                                                    <h3 class="text-sm font-semibold truncate group-hover:text-stamp transition-colors">
                                                        {project.name}
                                                    </h3>
                                                    <span
                                                        class:list={[
                                                            "text-[0.6rem] font-semibold uppercase tracking-wider",
                                                            project.status ===
                                                            "Live"
                                                                ? "text-stamp"
                                                                : project.status ===
                                                                    "Completed"
                                                                  ? "text-funded"
                                                                  : "text-stencil",
                                                        ]}
                                                    >
                                                        {project.status}
                                                    </span>
                                                </div>
                                                <i class="ph-bold ph-caret-right text-xs text-ink-faint/40 flex-shrink-0" />
                                            </div>
                                            <p class="text-xs text-stencil leading-relaxed line-clamp-2">
                                                {project.description}
                                            </p>
                                            {project.percent !== null && (
                                                <div class="mt-2.5">
                                                    <ProgressBar
                                                        percent={
                                                            project.percent
                                                        }
                                                        hot={
                                                            project.percent >=
                                                            100
                                                        }
                                                    />
                                                </div>
                                            )}
                                        </a>
                                    ))
                                }
                            </div>
                        </div>

                        <!-- ── ACTIVITY & WALL ── -->
                        <div id="wall" class="profile-section">
                            <div class="flex items-center justify-between mb-5">
                                <h2
                                    class="font-serif font-bold text-xl sm:text-2xl tracking-tight"
                                >
                                    Log
                                </h2>
                            </div>
                            <div class="space-y-4">
                                {
                                    activities.map((a) => (
                                        <div class="flex items-start gap-3">
                                            <div
                                                class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5"
                                                style={`background: ${a.highlight ? "rgba(217,72,0,0.1)" : "rgba(26,26,26,0.04)"}`}
                                            >
                                                <i
                                                    class={`ph-bold ph-${a.icon} text-sm`}
                                                    style={`color: ${a.highlight ? "#D94800" : "#4A3D2F"}`}
                                                />
                                            </div>
                                            <div class="flex-1">
                                                <p
                                                    class="text-sm text-ink leading-snug"
                                                    set:html={a.text}
                                                />
                                                <span class="text-xs text-ink-faint mt-0.5 block">
                                                    {a.time}
                                                </span>

                                                {a.miniCard && (
                                                    <div class="mt-2 p-3 rounded-lg bg-kraft-light/50 border border-ink/5">
                                                        <div class="flex items-center gap-2 mb-1.5">
                                                            <i
                                                                class={`ph-bold ph-${a.miniCard.icon} text-sm text-stencil`}
                                                            />
                                                            <span class="text-xs font-semibold text-ink">
                                                                {
                                                                    a.miniCard
                                                                        .name
                                                                }
                                                            </span>
                                                        </div>
                                                        <div
                                                            class="progress mb-1"
                                                            style="height:4px;"
                                                        >
                                                            <div
                                                                class="progress-fill"
                                                                style={`width: ${a.miniCard.percent}%`}
                                                            />
                                                        </div>
                                                        <div class="text-[0.6rem] text-ink-faint">
                                                            <strong class="text-ink font-semibold">
                                                                {
                                                                    a.miniCard
                                                                        .percent
                                                                }
                                                                %
                                                            </strong>{" "}
                                                            funded
                                                        </div>
                                                    </div>
                                                )}
                                            </div>
                                        </div>
                                    ))
                                }
                            </div>

                            <!-- Wall (interactive, store-backed) -->
                            <div class="border-t border-ink/5 pt-5 mt-6">
                                <CampaignDiscussion
                                    subjectType="maker"
                                    subjectId={maker.slug}
                                    title="Wall"
                                    seed={wallSeed}
                                    client:visible
                                />
                            </div>
                        </div>
                    </Card>
                </div>

                <!-- ══════════════════════════ -->
                <!-- SIDEBAR (RIGHT)            -->
                <!-- ══════════════════════════ -->
                <div class="w-full lg:w-80 flex-shrink-0">
                    <div class="lg:sticky lg:top-4 space-y-4">
                        <!-- Jump nav (desktop - easy access to every section) -->
                        <nav class="side-nav">
                            <a href="#overview" class="side-nav-link"
                                ><i class="ph-bold ph-identification-card"></i> Overview</a
                            >
