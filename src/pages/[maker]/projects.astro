---
// A maker's projects now live on the global /projects listing, filtered by
// ?maker=. This route 301-redirects there so old links keep working.
import { makers } from "../../data/makers";

export function getStaticPaths() {
  return makers.map((m) => ({ params: { maker: m.slug } }));
}

return Astro.redirect(`/projects?maker=${Astro.params.maker}`, 301);
---
