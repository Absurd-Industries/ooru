---
/**
 * Campaign detail route.
 *
 * Most campaigns render the generic, reusable template (`GenericCampaign`).
 * Campaigns flagged `richLayout` (currently CoryDora) take over this URL with a
 * bespoke, feature-first landing page; their generic version is still reachable
 * at `/[maker]/[campaign]/classic`.
 */
import GenericCampaign from "../../components/GenericCampaign.astro";
import CoryDoraLanding from "../../components/corydora/CoryDoraLanding.astro";
import { campaigns } from "../../data/campaigns";
import type { Campaign } from "../../types";

export function getStaticPaths() {
    return campaigns.map((campaign) => ({
        params: { maker: campaign.makerSlug, campaign: campaign.slug },
        props: { campaign },
    }));
}

interface Props {
    campaign: Campaign;
}
const { campaign } = Astro.props;
---

{
    campaign.richLayout ? (
        <CoryDoraLanding campaign={campaign} />
    ) : (
        <GenericCampaign campaign={campaign} />
    )
}
