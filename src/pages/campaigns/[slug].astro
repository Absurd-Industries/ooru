---
/**
 * Campaign detail page - dynamic route via getStaticPaths().
 *
 * For the "open-source-water-purifier" campaign (the primary example from
 * the reference design), this page renders the full detail layout:
 * hero, funding sidebar, BOM table, source files, manufacturing timeline,
 * updates feed, and threaded comments.
 *
 * Other campaigns get a simpler layout with basic campaign info.
 */

import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/Card.astro";
import Tag from "../../components/Tag.astro";
import ProgressBar from "../../components/ProgressBar.astro";
import GalleryViewer from "../../components/GalleryViewer.vue";
import FilePreview from "../../components/FilePreview.vue";
import CampaignDiscussion from "../../components/CampaignDiscussion.vue";
import CampaignRewards from "../../components/CampaignRewards.vue";
import { campaigns } from "../../data/campaigns";
import type { Campaign } from "../../types";
import { t } from "../../i18n";

// Backing model helpers: reserve 25% now, pay the balance on ship.
const priceNum = (s: string) => parseInt(String(s).replace(/[^\d]/g, ""), 10) || 0;
const inr = (n: number) => "₹" + n.toLocaleString("en-IN");
const depositOf = (price: string) => Math.round(priceNum(price) * 0.25);

export function getStaticPaths() {
  return campaigns.map((campaign) => ({
    params: { slug: campaign.slug },
    props: { campaign },
  }));
}

interface Props {
  campaign: Campaign;
}

const { campaign } = Astro.props;

// ---------------------------------------------------------------------------
// Mock detail data for the featured campaign
// (In production this would come from a CMS / D1 database.)
// ---------------------------------------------------------------------------

const isWaterPurifier = campaign.slug === "open-source-water-purifier";

// For campaigns that have the full detail treatment, we define rich data.
// Since our actual data file doesn't have a water purifier campaign,
// let's check for soilpulse (which has bornFromRequest) or lampy as the
// showcase. We'll use the first live campaign with bornFromRequest,
// or fall back to the first campaign.
const isShowcase = campaign.slug === "soilpulse-open-moisture-sensor" || campaign.slug === "supersaber-open-lightsaber-kit";

const bom = [
  { name: "Ceramic filter element", qty: "1", source: "Potters for Peace / local kiln", cost: "₹295" },
  { name: "UV-C LED array (4x 275nm)", qty: "1", source: "LCSC / Mouser", cost: "₹520" },
  { name: "Bamboo composite housing", qty: "1", source: "Local workshop", cost: "₹235" },
  { name: "Solar charge controller (MPPT)", qty: "1", source: "AliExpress / local", cost: "₹285" },
  { name: "12V 6Ah LiFePO4 battery pack", qty: "1", source: "EVE Energy / local", cost: "₹460" },
  { name: "10W solar panel", qty: "1", source: "Global sourcing", cost: "₹270" },
  { name: "Flow rate sensor (YF-S201)", qty: "1", source: "LCSC / AliExpress", cost: "₹92" },
  { name: "TDS sensor module", qty: "1", source: "AliExpress / local", cost: "₹75" },
  { name: "PCB + through-hole components", qty: "1", source: "JLCPCB / hand-solder", cost: "₹100" },
  { name: "Silicone tubing + fittings", qty: "1 set", source: "Local hardware store", cost: "₹59" },
];

// Bill of materials as downloadable CSV (generated from the table above).
const bomCsv =
  "Component,Qty,Source,Est. Cost (INR)\n" +
  bom
    .map(
      (b) =>
        `${b.name},${b.qty},${b.source.replace(/,/g, ";")},${b.cost.replace("₹", "")}`
    )
    .join("\n");

// Source files with real, previewable content - the heart of the
// open-source promise. Click any file to read it before you back it.
const files = [
  {
    name: "PCB Schematic",
    format: "KiCad",
    icon: "ph-bold ph-circuit-board",
    type: "code",
    filename: `${campaign.slug}.kicad_sch`,
    meta: "KiCad 8 schematic source",
    content: `(kicad_sch (version 20231120) (generator "eeschema")
  (uuid "a1b2c3d4-0000-4f00-8000-${campaign.slug.slice(0, 8).padEnd(8, "0")}")
  (paper "A4")
  (title_block
    (title "${campaign.title}")
    (company "Ooru / Open Hardware")
    (comment 1 "Licensed under ${campaign.license}")
  )
  (lib_symbols
    (symbol "MCU_Module:ESP32-WROOM-32"
      (pin power_in line (at 0 7.62 270) (name "3V3") (number "1")))
    (symbol "Sensor:SOIL-CAP-v2"
      (pin passive line (at -5.08 0 0) (name "SIG") (number "2")))
  )
  (wire (pts (xy 88.9 73.66) (xy 101.6 73.66)))
  (symbol (lib_id "MCU_Module:ESP32-WROOM-32") (at 95.25 80.01 0))
  (symbol (lib_id "Sensor:SOIL-CAP-v2") (at 60.96 90.17 0))
)`,
  },
  {
    name: "Firmware",
    format: "C",
    icon: "ph-bold ph-code",
    type: "code",
    filename: "firmware.c",
    meta: "Embedded C source",
    content: `// ${campaign.title} - firmware
// SPDX-License-Identifier: ${campaign.license}
#include "board.h"
#include "sensor.h"
#include "lora.h"

#define SAMPLE_INTERVAL_MS  60000
#define DEEP_SLEEP_ENABLED  1

void setup(void) {
  board_init();
  sensor_calibrate();
  lora_join_otaa();
}

void loop(void) {
  reading_t r = sensor_read();
  if (r.valid) {
    lora_send(&r, sizeof(r));
  }
#if DEEP_SLEEP_ENABLED
  board_deep_sleep(SAMPLE_INTERVAL_MS);
#else
  delay(SAMPLE_INTERVAL_MS);
#endif
}`,
  },
  {
    name: "3D Model",
    format: campaign.modelUrl ? "GLB / STEP" : "STEP",
    icon: "ph-bold ph-cube",
    type: campaign.modelUrl ? "3d" : "text",
    filename: "enclosure.step",
    modelUrl: campaign.modelUrl,
    meta: "Weatherproof enclosure",
    content: campaign.modelUrl
      ? undefined
      : `ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('${campaign.title} enclosure'),'2;1');
FILE_NAME('enclosure.step','2026-01-01T00:00:00',('Ooru'),(''),'','','');
FILE_SCHEMA(('AUTOMOTIVE_DESIGN { 1 0 10303 214 }'));
ENDSEC;
DATA;
#1 = CARTESIAN_POINT('',(0.,0.,0.));
#2 = DIRECTION('',(0.,0.,1.));
/* ... full B-rep solid omitted in preview - download to open in CAD ... */
ENDSEC;
END-ISO-10303-21;`,
  },
  {
    name: "Assembly Guide",
    format: "Guide",
    icon: "ph-bold ph-file-text",
    type: "text",
    filename: "assembly-guide.md",
    meta: "Step-by-step build",
    content: `# ${campaign.title} - Assembly Guide

## You will need
- 2.0mm hex driver, fine-tip soldering iron, flush cutters
- The parts in bom.csv (every part is sourceable - see the Source column)

## 1. Populate the board
Solder the through-hole components first, lowest profile to highest.
Double-check the diode and electrolytic cap orientation against the
silkscreen.

## 2. Flash the firmware
Connect over USB-C and run \`make flash\`. The firmware source is in
firmware.c - read it first, it is short on purpose.

## 3. Close the enclosure
Seat the board on the standoffs, route the sensor cable through the
grommet, and torque the 4 corner screws lightly. Do not over-tighten.

## 4. Field check
Power on. The status LED breathes while joining the network, then
pulses once per successful reading.

Licensed under ${campaign.license}. Remix freely.`,
  },
  {
    name: "Bill of Materials",
    format: "CSV",
    icon: "ph-bold ph-table",
    type: "csv",
    filename: "bom.csv",
    meta: `${bom.length} components`,
    content: bomCsv,
  },
];

const manufacturingSteps = [
  { label: "Design Complete", note: "All CAD, schematics, and firmware finalized", status: "done" },
  { label: "Prototyping", note: "3 prototype iterations completed", status: "done" },
  { label: "Testing", note: "Field testing in 3 villages in Karnataka", status: "current" },
  { label: "Production Setup", note: "Tooling and supply chain preparation", status: "pending" },
  { label: "Shipping", note: "Fulfillment to backers worldwide", status: "pending" },
];

const updates = [
  {
    date: "June 2, 2026",
    title: "Prototype v3 passed field testing!",
    text: "After 5 months of continuous operation in three test sites, Prototype v3 has exceeded all performance targets. Lab results confirm 99.97% bacteria removal and 99.9% virus inactivation. The bamboo housing showed zero degradation despite monsoon conditions. We are now finalizing the production BOM.",
  },
  {
    date: "April 18, 2026",
    title: "UV-C LED driver redesigned for reliability",
    text: "We discovered thermal issues with the original LED driver during extended operation in direct sunlight. The redesigned board uses a more conservative derating curve and adds a thermistor-based cutoff. Updated KiCad files have been pushed to the repository.",
  },
  {
    date: "February 5, 2026",
    title: "Prototype v2 deployed for field testing",
    text: "Three units deployed across rural sites near Mysore. Each unit is processing 100-140 liters per day for households of 5-8 people. Community health workers are logging daily output and collecting water samples for monthly lab analysis. Early feedback on usability has been very positive.",
  },
];

const rewardTiers = [
  {
    name: "Source Supporter",
    price: "₹500",
    blurb: "Back the mission and get every design file the moment we ship.",
    perks: [
      "Full source files (schematics, CAD, firmware)",
      "Name in the project credits",
      "Backer-only build updates",
    ],
    delivery: "Sep 2026",
    ships: "Digital - no shipping",
    backers: 56,
    claimed: 56,
    total: null,
  },
  {
    name: "Early Bird",
    price: "₹1,500",
    blurb: "The complete unit at a thank-you price for the first backers.",
    perks: [
      "1 fully assembled unit",
      "Complete schematics and source files",
      "Name in project credits",
    ],
    delivery: "Oct 2026",
    ships: "Worldwide",
    backers: 42,
    claimed: 42,
    total: 50,
  },
  {
    name: "Maker Bundle",
    price: "₹3,500",
    blurb: "Build it yourself - every part, plus extras and a printed guide.",
    perks: [
      "1 complete kit (unassembled) with all parts",
      "3 extra filter elements",
      "Your name etched on the PCB silkscreen",
      "Printed assembly guide",
    ],
    delivery: "Oct 2026",
    ships: "Worldwide",
    backers: 89,
    claimed: 89,
    total: 150,
  },
  {
    name: "Workshop Pack",
    price: "₹12,000",
    blurb: "Everything a makerspace needs to run a build session.",
    perks: [
      "5 complete units (assembled)",
      "Workshop hosting guide and slides",
      "Priority email support from the maker",
      "Logo placement on project page",
    ],
    delivery: "Nov 2026",
    ships: "Worldwide",
    backers: 12,
    claimed: 12,
    total: 30,
  },
];

// Every campaign gets a sensible default set of tiers derived from its own numbers.
const genericTiers = [
  {
    name: "Source Supporter",
    price: "₹500",
    blurb: "Back the build and get every open-source file the day we ship.",
    perks: [
      "Full source files under " + campaign.license,
      "Name in the project credits",
      "Backer-only build updates",
    ],
    delivery: "Sep 2026",
    ships: "Digital - no shipping",
    backers: Math.max(8, Math.round(campaign.backers * 0.18)),
    claimed: Math.max(8, Math.round(campaign.backers * 0.18)),
    total: null,
  },
  {
    name: "Early Bird",
    price: "₹2,500",
    blurb: "The complete, assembled product at a thank-you price.",
    perks: [
      "1 fully assembled unit",
      "Complete source files and documentation",
      "Name in project credits",
    ],
    delivery: "Oct 2026",
    ships: "Worldwide",
    backers: Math.max(20, Math.round(campaign.backers * 0.45)),
    claimed: 60,
    total: 75,
  },
  {
    name: "Maker Kit",
    price: "₹4,500",
    blurb: "Every part to build it yourself, plus a printed assembly guide.",
    perks: [
      "Complete kit (unassembled) with all parts",
      "Step-by-step printed assembly guide",
      "Your name on the PCB silkscreen",
    ],
    delivery: "Nov 2026",
    ships: "Worldwide",
    backers: Math.max(10, Math.round(campaign.backers * 0.3)),
    claimed: 38,
    total: 120,
  },
];

const tiers = isShowcase ? rewardTiers : genericTiers;

// Generic updates so every campaign's Updates tab has content.
const genericUpdates = [
  {
    date: "Two weeks ago",
    title: "We hit a major prototyping milestone",
    text: "The latest revision is assembled and running on the bench. Everything from the enclosure fit to the firmware is behaving as designed, and we are moving into a longer reliability run before we lock the production files. Thank you for getting us here.",
  },
  {
    date: "One month ago",
    title: "Source files are live in the repository",
    text: "As promised, the full design package is public from day one - schematics, CAD, and firmware are all in the project repository under " + campaign.license + ". Browse them, build along, and tell us what you would change.",
  },
];

const updatesList = isShowcase ? updates : genericUpdates;

// Campaign FAQ - applies to every project.
const faqs = [
  {
    q: "When will rewards ship?",
    a: "Estimated delivery is on each reward tier. We only commit to dates we are confident in - if anything slips, backers hear it first in an update, with the reason and a new estimate.",
  },
  {
    q: "Is this really fully open source?",
    a: "Yes. Every schematic, board file, 3D model, and line of firmware is released under " + campaign.license + ". You can study it, repair it, manufacture it, and remix it - that is the whole point of building on Ooru.",
  },
  {
    q: "Can I build it myself instead of backing a unit?",
    a: "Absolutely. The Source Supporter tier gets you the complete file package, and the bill of materials lists every part with a place to buy it. The Maker Kit tier ships you the parts if you would rather not source them.",
  },
  {
    q: "Do you ship internationally?",
    a: "Yes - physical rewards ship worldwide. Any duties or import taxes are the backer's responsibility and are not included in the pledge amount.",
  },
  {
    q: "What happens if the campaign is not fully funded?",
    a: "This is an all-or-nothing campaign. If we do not reach the goal, no one is charged and no rewards ship. You are only backing a project that has the support to actually happen.",
  },
];

// Risks & Challenges - a Kickstarter-required section.
const risks = `Building open hardware in the open means we share our challenges as readily as our wins. The core technology is already working in our prototypes, so the largest remaining risks are in manufacturing and fulfilment: component lead times can shift, and moving from a hand-built prototype to a repeatable production run always surfaces small surprises.

We have de-risked this by finalising the design before launching, sourcing every part from at least two suppliers, and field-testing real units rather than bench mock-ups. Because the entire design is open, you are never locked in - if we ever could not finish, the complete files are already public so the community can carry it forward. We will keep you honest with regular, specific updates at every step.`;

// Lightweight creator stats for the maker card.
const creatorStats = {
  created: 1 + (campaign.backers % 3),
  backed: 4 + (campaign.backers % 11),
  firstCreated: campaign.backers % 3 === 0,
};

const estDelivery = campaign.status === "coming" ? "TBA" : "September 2026";

const comments = [
  {
    id: 1,
    author: "Rahul Deshmukh",
    initials: "RD",
    color: "#2A5F41",
    badge: "Backer",
    badgeVariant: "funded" as const,
    time: "3 days ago",
    content: "Backed the Maker Bundle tier. I run a small NGO in rural Maharashtra and we have been looking for exactly this kind of solution. The fact that the filters can be manufactured locally is a game changer for us. How difficult is the production process?",
    replies: [
      {
        id: 101,
        author: campaign.makerName,
        initials: campaign.makerName.split(" ").map((w: string) => w[0]).join(""),
        color: "#D94800",
        badge: "Creator",
        badgeVariant: "stamp" as const,
        time: "2 days ago",
        content: "Great question! The filter production follows the Potters for Peace protocol, specifically designed to be teachable to local potters. A potter with basic experience can learn the process in about 2 days. We have a detailed training guide in the repository.",
      },
    ],
  },
  {
    id: 2,
    author: "Dr. Meena Iyer",
    initials: "MI",
    color: "#4A3D2F",
    badge: null,
    badgeVariant: "default" as const,
    time: "5 days ago",
    content: "As a public health researcher, I want to highlight how important the dual-barrier approach is in this design. Ceramic filters alone handle bacteria well, but they are unreliable against viruses. The UV-C stage is the right call. Have you considered adding a chlorine dosing option as a tertiary backup?",
    replies: [
      {
        id: 201,
        author: campaign.makerName,
        initials: campaign.makerName.split(" ").map((w: string) => w[0]).join(""),
        color: "#D94800",
        badge: "Creator",
        badgeVariant: "stamp" as const,
        time: "4 days ago",
        content: "Thanks for the expert perspective! We considered chlorine dosing but decided against it for v1 because it adds supply chain complexity. For high-turbidity events, we recommend a pre-settlement step using alum. The modular design means a chlorine stage could be added later.",
      },
    ],
  },
  {
    id: 3,
    author: "Kenji Tanaka",
    initials: "KT",
    color: "#1A1A1A",
