];

const statusLabel = campaign.status === "live" ? "Live" : campaign.status === "funded" ? "Funded" : "Coming Soon";
const statusVariant = campaign.status === "live" ? "stamp" : campaign.status === "funded" ? "funded" : "default";

// In-page section nav (Kickstarter-style sticky tabs). Only lists sections that render.
const sectionNav = [
  { id: "story", label: "Story" },
  { id: "rewards", label: "Rewards" },
  { id: "updates", label: "Updates", count: updatesList.length },
  { id: "faq", label: "FAQ", count: faqs.length },
  { id: "comments", label: "Comments", count: isShowcase ? comments.length : 0 },
];

// SEO: contextual OG image (campaign photo + title) + structured data.
const ogImagePath = `/og/campaigns/${campaign.slug}.jpg`;
const campaignLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: campaign.title,
  description: campaign.tagline,
  image: new URL(ogImagePath, Astro.site).href,
  category: campaign.category,
  brand: { "@type": "Brand", name: campaign.makerName },
  url: new URL(`/campaigns/${campaign.slug}`, Astro.site).href,
  license:
    "https://spdx.org/licenses/" + campaign.license.replace(/\s+/g, "") + ".html",
};
---

<BaseLayout
  title={campaign.title}
  description={campaign.tagline}
  ogImage={ogImagePath}
  ogType="article"
  jsonLd={campaignLd}
  activeTab="campaigns"
  hideNav
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-8 pb-24 md:pt-12 md:pb-28">

    <div class="flex flex-col lg:flex-row gap-6">

      <!-- ===== Main Column ===== -->
      <div class="flex-1 min-w-0">

        <Card>

            <!-- Hero media - full-bleed with overlaid nav buttons -->
            <div class="campaign-section campaign-section--hero">
              <div class="hero-media-wrap">
                {campaign.gallery && campaign.gallery.length > 0 ? (
                  <GalleryViewer images={campaign.gallery} alt={campaign.title} client:visible />
                ) : campaign.image ? (
                  <div class="h-48 sm:h-64 overflow-hidden" style="border-radius: 0.875rem 0.875rem 0 0;">
                    <img src={campaign.image} alt={campaign.title} class="w-full h-full object-cover" />
                  </div>
                ) : (
                  <div class="h-48 sm:h-64 bg-kraft-light flex items-center justify-center" style="border-radius: 0.875rem 0.875rem 0 0;">
                    <i class:list={[campaign.icon, "text-7xl sm:text-8xl text-stencil opacity-40"]}></i>
                  </div>
                )}
                <a href="/campaigns" class="hero-overlay-btn hero-overlay-btn--back" title="Back to campaigns">
                  <i class="ph-bold ph-arrow-left"></i>
                </a>
                <button class="hero-overlay-btn hero-overlay-btn--share share-float-btn" title="Copy link">
                  <i class="ph-bold ph-share-network"></i>
                </button>
              </div>
            </div>

            <!-- Title + tags + maker info -->
            <div class="campaign-section">
              <h1 class="font-serif text-2xl sm:text-3xl md:text-4xl font-black tracking-tight leading-tight mb-3">
                {campaign.title}
              </h1>

              <div class="flex flex-wrap items-center gap-2 mb-4">
                <Tag variant={statusVariant}>{statusLabel}</Tag>
                <Tag>{campaign.category}</Tag>
                <Tag>
                  <i class="ph-bold ph-scales mr-1" style="font-size: 0.65rem;"></i>
                  {campaign.license}
                </Tag>
              </div>

              <div class="flex flex-wrap items-center gap-3 text-sm text-ink-faint">
                <span>
                  by <a href={`/makers/${campaign.makerSlug}`} class="font-semibold text-ink hover:text-stamp transition-colors" style="text-decoration:none;">{campaign.makerName}</a>
                </span>
                <span class="flex items-center gap-1">
                  <i class="ph-bold ph-map-pin text-xs"></i>
                  {campaign.location}
                </span>
              </div>
            </div>

            <!-- Sticky in-page section nav (Kickstarter-style tabs) -->
            <nav class="section-nav" id="section-nav">
              {sectionNav.map((s) => (
                <a href={`#sec-${s.id}`} class="section-nav-link" data-target={`sec-${s.id}`}>
                  {s.label}
                  {s.count != null && <span class="section-nav-count">{s.count}</span>}
                </a>
              ))}
            </nav>

            <!-- Born from request callout -->
            {campaign.bornFromRequest && (
              <div class="campaign-section">
                <div style="border-left: 3px solid #D94800; padding-left: 1rem;">
                  <div class="flex items-start gap-3">
                    <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background: rgba(217,72,0,0.08);">
                      <i class="ph-bold ph-megaphone text-stamp"></i>
                    </div>
                    <div>
                      <p class="text-sm leading-relaxed">
                        This campaign was born from a community
                        <a href={`/requests/${campaign.bornFromRequest}`} class="font-semibold text-stamp hover:underline" style="text-decoration:none;">
                          request
                        </a>
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            )}

            <!-- About This Project -->
            <div class="campaign-section" id="sec-story">
              <h2 class="font-serif font-bold text-lg mb-4" data-i18n="campaign.about">{t("campaign.about")}</h2>
              <div class="text-sm leading-relaxed text-ink-light space-y-4">
                <p>{campaign.tagline}</p>
                {campaign.richDescription && (
                  <div class="whitespace-pre-line">{campaign.richDescription}</div>
                )}
                {isShowcase && (
                  <>
                    <p>
                      LoRa-connected soil sensors designed for small farms across India and Southeast Asia. Each node is
                      solar-powered and rated for 3 years of continuous operation without battery replacement. The sensor
                      array communicates via LoRaWAN to a central gateway that pushes data to any MQTT-compatible dashboard.
                    </p>
                    <p>
                      All hardware designs are released under CERN-OHL-S. The KiCad schematics, STEP models for the
                      weatherproof enclosure, and the firmware source (written in Rust for the nRF52840) are all available
                      in the project repository. We want farmers and agricultural researchers to be able to build, modify,
                      and manufacture these sensors without any licensing restrictions.
                    </p>
                  </>
                )}
              </div>
            </div>

            <!-- Campaign Video -->
            {campaign.videoUrl && (
              <div class="campaign-section">
                <h2 class="font-serif font-bold text-lg mb-3">
                  <i class="ph-duotone ph-video-camera mr-2" style="font-size:1rem;"></i>
                  Campaign Video
                </h2>
                <div class="aspect-video rounded-lg overflow-hidden">
                  <iframe
                    src={campaign.videoUrl}
                    title={`${campaign.title} demo video`}
                    class="w-full h-full"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                  ></iframe>
                </div>
              </div>
            )}

            <!-- Build Gallery -->
            {campaign.gallery && campaign.gallery.length > 0 && (
              <div class="campaign-section">
                <h2 class="font-serif font-bold text-lg mb-3">
                  <i class="ph-duotone ph-images mr-2" style="font-size:1rem;"></i>
                  Build Gallery
                </h2>
                <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                  {campaign.gallery.map((img, idx) => (
                    <div class="aspect-square rounded-lg overflow-hidden">
                      <img src={img} alt={`${campaign.title} build photo ${idx + 1}`} class="w-full h-full object-cover" />
                    </div>
                  ))}
                </div>
              </div>
            )}

            <!-- 3D Model -->
            {campaign.modelUrl && (
              <div class="campaign-section">
                <h2 class="font-serif font-bold text-lg mb-3">
                  <i class="ph-duotone ph-cube mr-2" style="font-size:1rem;"></i>
                  3D Model
                </h2>
                <div class="rounded-lg overflow-hidden" style="height: 400px; background: #F5F0EB;">
                  <model-viewer
                    src={campaign.modelUrl}
                    alt={`${campaign.title} 3D model`}
                    camera-controls
                    auto-rotate
                    shadow-intensity="1"
                    style="width: 100%; height: 100%;"
                  ></model-viewer>
                </div>
                <p class="text-xs text-stencil mt-2">Drag to rotate, scroll to zoom, pinch on mobile</p>
              </div>
            )}

            <!-- PCB Design -->
            {campaign.pcbViewerUrl && (
              <div class="campaign-section">
                <h2 class="font-serif font-bold text-lg mb-3">
                  <i class="ph-duotone ph-circuit-board mr-2" style="font-size:1rem;"></i>
                  PCB Design
                </h2>
                <div class="rounded-lg overflow-hidden" style="height: 400px; border: 1px solid rgba(26,26,26,0.08);">
                  <iframe
                    src={campaign.pcbViewerUrl}
                    title={`${campaign.title} PCB design`}
                    class="w-full h-full"
                    style="border: none;"
                  ></iframe>
                </div>
              </div>
            )}

            <!-- Open Source Files -->
            {isShowcase ? (
              <div class="campaign-section" id="sec-files">
                <div class="flex items-center justify-between mb-1">
                  <h2 class="font-serif font-bold text-lg" data-i18n="campaign.files">{t("campaign.files")}</h2>
                  <Tag variant="funded">
                    <i class="ph-bold ph-scales mr-1" style="font-size: 0.65rem;"></i>
                    {campaign.license}
                  </Tag>
                </div>
                <p class="text-xs text-ink-faint mb-4">Preview every file before you back it - read the firmware, inspect the BOM, spin the model.</p>

                <FilePreview files={files} campaignSlug={campaign.slug} license={campaign.license} client:visible />
              </div>
            ) : (
              <div class="campaign-section">
                <h2 class="font-serif font-bold text-lg mb-4" data-i18n="campaign.files">{t("campaign.files")}</h2>
                <Tag variant="funded">
                  <i class="ph-bold ph-scales mr-1" style="font-size: 0.65rem;"></i>
                  {campaign.license}
                </Tag>
                <p class="text-sm text-ink-faint mt-3 leading-relaxed">
                  All source files for this project will be released under the {campaign.license} license.
                  CAD files, schematics, firmware, and documentation will be available for download once the campaign is funded.
                </p>
              </div>
            )}

            <!-- BOM Table (showcase only) -->
            {isShowcase && (
              <div class="campaign-section">
                <div class="flex items-center justify-between mb-4">
                  <h2 class="font-serif font-bold text-lg" data-i18n="campaign.bom">{t("campaign.bom")}</h2>
                  <Tag>
                    <i class="ph-bold ph-table mr-1" style="font-size: 0.65rem;"></i>
                    {bom.length} components
                  </Tag>
                </div>

                <div class="overflow-x-auto -mx-2">
                  <table class="bom-table">
                    <thead>
                      <tr>
                        <th data-i18n="campaign.bomComponent">{t("campaign.bomComponent")}</th>
                        <th>Qty</th>
                        <th class="hidden sm:table-cell" data-i18n="campaign.bomSource">{t("campaign.bomSource")}</th>
                        <th class="text-right">Est. Cost</th>
                      </tr>
                    </thead>
                    <tbody>
                      {bom.map((item) => (
                        <tr>
                          <td class="font-medium">{item.name}</td>
                          <td>{item.qty}</td>
                          <td class="hidden sm:table-cell text-ink-faint">{item.source}</td>
                          <td class="text-right">{item.cost}</td>
                        </tr>
                      ))}
                      <tr class="total-row">
                        <td colspan="2" class="hidden sm:table-cell"></td>
                        <td class="sm:hidden"></td>
                        <td class="hidden sm:table-cell text-right font-semibold" data-i18n="campaign.bomTotal">{t("campaign.bomTotal")}</td>
                        <td class="sm:hidden text-right font-semibold" data-i18n="campaign.bomTotal">{t("campaign.bomTotal")}</td>
                        <td class="text-right font-semibold">~&#8377;2,400</td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            <!-- Manufacturing Status (showcase only) -->
            {isShowcase && (
              <div class="campaign-section">
                <h2 class="font-serif font-bold text-lg mb-5" data-i18n="campaign.mfgStatus">{t("campaign.mfgStatus")}</h2>

                {manufacturingSteps.map((step, idx) => (
                  <>
                    <div class="flex items-center gap-3">
                      <div
                        class:list={[
                          "step-dot",
                          step.status === "done" && "bg-funded text-paper",
                          step.status === "current" && "bg-stamp text-paper",
                          step.status === "pending" && "bg-kraft-light text-stencil",
                        ]}
                      >
                        {step.status === "done" && <i class="ph-bold ph-check"></i>}
                        {step.status === "current" && <i class="ph-bold ph-circle-notch"></i>}
                        {step.status === "pending" && <i class="ph-bold ph-circle-dashed"></i>}
                      </div>
                      <div class="flex-1">
                        <div class:list={["text-sm font-semibold", step.status === "pending" && "text-ink-faint"]}>
                          {step.label}
                        </div>
                        <div class="text-xs text-ink-faint">{step.note}</div>
                      </div>
                      {step.status === "current" && <Tag variant="stamp"><span data-i18n="campaign.inProgress">{t("campaign.inProgress")}</span></Tag>}
                      {step.status === "done" && <Tag variant="funded"><span data-i18n="campaign.complete">{t("campaign.complete")}</span></Tag>}
                    </div>
                    {idx < manufacturingSteps.length - 1 && (
                      <div
                        class:list={[
                          "step-line",
                          step.status === "done" && "bg-funded",
                          step.status === "current" && "bg-stamp",
                          step.status === "pending" && "bg-kraft-light",
                        ]}
                      ></div>
                    )}
                  </>
                ))}
              </div>
            )}

            <!-- Risks & Challenges (Kickstarter-standard section) -->
            <div class="campaign-section" id="sec-risks">
              <h2 class="font-serif font-bold text-lg mb-3">
                <i class="ph-duotone ph-warning-circle mr-2" style="font-size:1rem;"></i>
                Risks &amp; Challenges
              </h2>
              <div class="text-sm leading-relaxed text-ink-light space-y-4 whitespace-pre-line">{risks}</div>
            </div>

            <!-- FAQ -->
            <div class="campaign-section" id="sec-faq">
              <h2 class="font-serif font-bold text-lg mb-4" data-i18n="campaign.faqTitle">{t("campaign.faqTitle")}</h2>
              <div class="campaign-faq">
                {faqs.map((f) => (
                  <details class="campaign-faq-item" name="campaign-faq">
                    <summary class="campaign-faq-q">
                      <span>{f.q}</span>
                      <i class="ph-bold ph-caret-down campaign-faq-caret"></i>
                    </summary>
                    <div class="campaign-faq-a">{f.a}</div>
                  </details>
                ))}
              </div>
              <p class="text-xs text-ink-faint mt-4">
                Still curious? <a href="https://discord.gg/DUSUtguG2H" target="_blank" rel="noopener" class="text-stamp hover:underline" style="text-decoration:none;" data-i18n="campaign.askMaker">{t("campaign.askMaker")}</a>.
              </p>
            </div>

            <!-- Updates Feed -->
            <div class="campaign-section" id="sec-updates">
              <h2 class="font-serif font-bold text-lg mb-5"><span data-i18n="campaign.updates">{t("campaign.updates")}</span> <span class="text-sm font-sans font-normal text-ink-faint ml-1">({updatesList.length})</span></h2>

                {updatesList.map((update, idx) => (
                  <div class="flex gap-3">
                    <div class="flex flex-col items-center flex-shrink-0">
                      <div class:list={["w-3 h-3 rounded-full mt-1", idx === 0 ? "bg-stamp" : "bg-kraft-dark"]}></div>
                      {idx < updatesList.length - 1 && (
                        <div class:list={["w-0.5 flex-1 mt-1", idx === 0 ? "bg-stamp/30" : "bg-kraft-dark/20"]}></div>
                      )}
                    </div>
                    <div class="pb-6">
                      <div class="text-xs text-ink-faint mb-1">{update.date}</div>
                      <h4 class="text-sm font-semibold mb-1">{update.title}</h4>
                      <p class="text-sm text-ink-faint leading-relaxed">{update.text}</p>
                    </div>
                  </div>
                ))}
              </div>

            <!-- Discussion -->
            <div class="campaign-section" id="sec-comments">
              <CampaignDiscussion
                subjectId={campaign.slug}
                makerName={campaign.makerName}
                seed={isShowcase
                  ? comments.map((c, i) => ({
                      ...c,
                      hearts: [9, 14, 6, 4][i] ?? 3,
                      replies: (c.replies || []).map((r) => ({ ...r, hearts: 5 })),
                    }))
                  : []}
                client:visible
              />
            </div>

        </Card>

      </div>

      <!-- ===== Sidebar ===== -->
      <div class="w-full lg:w-80 flex-shrink-0">

        <!-- Funding Progress -->
        <Card class="mb-5">
          <div class="p-5">
            <div class="funding-amount">{campaign.raisedFormatted}</div>
            <div class="text-xs text-ink-faint mb-3">pledged of {campaign.goalFormatted} goal</div>

            <div class="mb-4" style="height: 7px;">
              <ProgressBar percent={campaign.percent} hot={campaign.percent >= 90 && campaign.status === "live"} />
            </div>

            <div class="funding-stats">
              <div class="funding-stat">
                <div class="funding-stat-num">{campaign.percent}%</div>
                <div class="funding-stat-label" data-i18n="campaign.statFunded">{t("campaign.statFunded")}</div>
              </div>
              <div class="funding-stat">
                <div class="funding-stat-num">{campaign.backers}</div>
                <div class="funding-stat-label" data-i18n="campaign.statBackers">{t("campaign.statBackers")}</div>
              </div>
              {campaign.daysLeft != null && (
                <div class="funding-stat">
                  <div class="funding-stat-num">{campaign.daysLeft}</div>
                  <div class="funding-stat-label" data-i18n="campaign.statDaysLeft">{t("campaign.statDaysLeft")}</div>
                </div>
              )}
            </div>

            {campaign.status === "live" && (
              <a href="#sec-rewards" class="btn btn-stamp w-full mt-4" style="text-decoration:none;">
                <i class="ph-bold ph-heart mr-2"></i>Back This Project
              </a>
            )}
            {campaign.status === "funded" && (
              <div class="btn w-full mt-4" style="background: #2A5F41; color: #FAF3E8; cursor: default;">
                <i class="ph-bold ph-check-circle mr-2"></i>Fully Funded
              </div>
            )}
            {campaign.status === "coming" && (
              <button onclick="window.__comingSoon && window.__comingSoon('Get Notified', 'Sign up for launch notifications so you never miss this campaign going live.')" class="btn btn-outline w-full mt-4">
                <i class="ph-bold ph-bell mr-2"></i>Notify Me
              </button>
            )}

            {campaign.status === "live" && (
              <p class="funding-note">
                <i class="ph-bold ph-shield-check"></i>
                <span>Reserve for 25% now, pay the rest on ship. Cancel before shipment for a full refund.</span>
              </p>
            )}

            <div class="funding-foot">
              <span><i class="ph-bold ph-calendar-blank"></i> Est. delivery {estDelivery}</span>
              <button class="funding-share share-float-btn"><i class="ph-bold ph-share-network"></i> Share</button>
            </div>
          </div>
        </Card>

        <!-- Project folio cross-link -->
        {campaign.projectSlug && (
          <a href={`/projects/${campaign.projectSlug}`} class="folio-link-card mb-5" style="text-decoration:none;">
            <div class="folio-link-icon">
              <i class="ph-duotone ph-folder-open"></i>
            </div>
            <div class="folio-link-body">
              <div class="folio-link-title">Project Folio</div>
              <div class="folio-link-sub">Build guide, 3D model, BOM &amp; source files</div>
            </div>
            <i class="ph-bold ph-arrow-right folio-link-arrow"></i>
          </a>
        )}

        <!-- Rewards rail (right side on desktop, stacks on mobile) -->
        {campaign.status === "live" && (
          <CampaignRewards tiers={tiers} campaignSlug={campaign.slug} client:visible />
        )}

        <!-- Creator Card -->
        <Card class="mb-5">
          <div class="p-5">
            <div class="text-[0.6rem] font-bold uppercase tracking-wider text-ink-faint mb-3" data-i18n="campaign.creator">{t("campaign.creator")}</div>
            <div class="flex items-center gap-3 mb-4">
              <div
                class="w-12 h-12 flex items-center justify-center text-sm font-bold text-paper flex-shrink-0 oct-sm"
                style={`background: ${campaign.avatarColor}`}
              >
                {campaign.makerName.split(" ").map((w) => w[0]).join("")}
              </div>
              <div class="min-w-0">
                <div class="font-semibold text-sm leading-tight">{campaign.makerName}</div>
                <div class="text-xs text-ink-faint flex items-center gap-1">
                  <i class="ph-bold ph-map-pin" style="font-size:0.7rem;"></i>{campaign.location}
                </div>
              </div>
            </div>

            <div class="creator-stats">
              <div>
                <div class="creator-stat-num">{creatorStats.created}</div>
                <div class="creator-stat-label">{creatorStats.created === 1 ? "campaign" : "campaigns"} created</div>
              </div>
              <div>
                <div class="creator-stat-num">{creatorStats.backed}</div>
                <div class="creator-stat-label" data-i18n="campaign.projectsBacked">{t("campaign.projectsBacked")}</div>
              </div>
            </div>

            {creatorStats.firstCreated && (
              <div class="creator-badge">
                <i class="ph-bold ph-seal-check"></i> First created on Ooru
              </div>
            )}

            <p class="text-xs text-ink-light leading-relaxed mt-3 mb-4">
              Building open hardware in {campaign.location}. Every project ships with full source files so you can study, repair, and remix it.
            </p>

            <div class="grid grid-cols-2 gap-2">
              <a href={`/makers/${campaign.makerSlug}`} class="btn btn-outline btn-sm w-full" style="text-decoration:none;" data-i18n="campaign.profile">{t("campaign.profile")}</a>
              <button onclick="window.__comingSoon && window.__comingSoon('Contact the maker', 'Direct messaging launches with the next platform update. For now, find the maker on Discord.')" class="btn btn-outline btn-sm w-full" data-i18n="nav.contact">{t("nav.contact")}</button>
            </div>
          </div>
        </Card>

      </div>
    </div>
  </div>

  <!-- Floating CTA pill (phones only - scrolls to the rewards rail) -->
  <div class="float-pill" id="campaign-float">
    {campaign.status === "live" && (
      <a href="#sec-rewards" class="float-pill-btn" style="text-decoration:none;">
        <div class="float-pill-info">
          <span class="float-pill-title">{campaign.percent}% funded</span>
          <span class="float-pill-sub">{campaign.backers} backers</span>
        </div>
        <div class="float-pill-right">
          <span class="float-pill-label" data-i18n="campaign.back">{t("campaign.back")}</span>
          <i class="ph-bold ph-arrow-up float-pill-chevron" style="font-size:0.7rem;"></i>
        </div>
      </a>
    )}
    {campaign.status === "funded" && (
      <div class="float-pill-btn float-pill-btn--funded">
        <div class="float-pill-info">
          <span class="float-pill-title" data-i18n="campaign.fullyFunded">{t("campaign.fullyFunded")}</span>
          <span class="float-pill-sub">{campaign.backers} backers</span>
        </div>
        <div class="float-pill-right">
          <i class="ph-bold ph-check-circle" style="font-size:0.8rem; opacity:0.5;"></i>
        </div>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  /* Flowing sections inside campaign card */
  .campaign-section {
    padding: 1.25rem 1.5rem;
    border-top: 1px solid rgba(26, 26, 26, 0.06);
  }
  .campaign-section:first-child {
    border-top: none;
  }
  .campaign-section--hero {
    padding: 0;
    border-top: none;
  }
  @media (min-width: 640px) {
    .campaign-section {
      padding: 1.75rem 2rem;
    }
    .campaign-section--hero {
      padding: 0;
    }
  }

  /* Floating pill CTA */
  .float-pill {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    right: 1rem;
    z-index: 40;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    max-width: 42rem;
    margin: 0 auto;
  }
  /* Phones only - desktop has the rewards rail + funding panel visible */
  @media (min-width: 1024px) {
    .float-pill { display: none !important; }
  }
  @media (min-width: 640px) {
    .float-pill {
      left: 1.5rem;
      right: 1.5rem;
      bottom: 1.5rem;
      max-width: 42rem;
      margin: 0 auto;
    }
  }

  .float-pill-btn {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: 0.875rem;
    background: rgba(26, 26, 26, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    color: #FAF3E8;
    border: none;
    cursor: pointer;
    text-align: left;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(26, 26, 26, 0.25), 0 0 0 1px rgba(26, 26, 26, 0.05);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .float-pill-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(26, 26, 26, 0.3), 0 0 0 1px rgba(26, 26, 26, 0.08);
  }
  .float-pill-btn:active {
    transform: translateY(0);
  }
  .float-pill-btn--funded {
    background: #2A5F41;
    cursor: default;
  }
  .float-pill-btn--funded:hover {
    transform: none;
  }
  .float-pill-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .float-pill-title {
    font-family: 'Fraunces', serif;
    font-weight: 700;
    font-size: 0.9rem;
    line-height: 1.2;
  }
  .float-pill-sub {
    font-size: 0.65rem;
    opacity: 0.5;
    margin-top: 0.1rem;
  }
  .float-pill-right {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
  }
  .float-pill-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(250, 243, 232, 0.5);
    white-space: nowrap;
    transition: color 0.15s;
  }
  .float-pill-btn:hover .float-pill-label {
    color: #FF5900;
  }
  /* Float pill chevron indicator */
  .float-pill-chevron {
    transition: transform 0.25s;
    margin-left: 2px;
  }
  .float-pill-btn.open .float-pill-chevron {
    transform: rotate(180deg);
  }

  /* Expanded tier panel */
  .float-pill-panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.2, 0, 0, 1), padding 0.35s, margin 0.35s, opacity 0.25s;
    background: rgba(26, 26, 26, 0.94);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 0.875rem;
    margin-bottom: 0;
    padding: 0;
    opacity: 0;
  }
  .float-pill-panel.expanded {
    max-height: 450px;
    padding: 0;
    margin-bottom: 0.625rem;
    box-shadow: 0 8px 32px rgba(26, 26, 26, 0.35);
    opacity: 1;
  }

  /* Hero overlay navigation buttons */
  .hero-media-wrap {
    position: relative;
  }
  .hero-overlay-btn {
    position: absolute;
    z-index: 10;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(26, 26, 26, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: #FAF3E8;
    border: 1.5px solid rgba(250, 243, 232, 0.15);
    cursor: pointer;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    text-decoration: none;
  }
  .hero-overlay-btn:hover {
    background: rgba(26, 26, 26, 0.8);
    border-color: rgba(250, 243, 232, 0.3);
  }
  .hero-overlay-btn--back {
    top: 12px;
    left: 12px;
  }
  .hero-overlay-btn--share {
    top: 12px;
    right: 12px;
  }

  /* Octagonal avatar helper */
  .oct-sm {
    clip-path: url(#rounded-octagon);
  }

  /* Project folio cross-link card */
  .folio-link-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: rgba(26, 26, 26, 0.04);
    border: 1.5px solid rgba(26, 26, 26, 0.1);
    border-radius: 0.875rem;
    transition: all 0.15s;
  }
  .folio-link-card:hover {
    border-color: #D94800;
    background: rgba(217, 72, 0, 0.05);
    transform: translateY(-1px);
  }
  .folio-link-icon { font-size: 1.4rem; color: #6B5B4A; flex-shrink: 0; transition: color 0.15s; }
  .folio-link-card:hover .folio-link-icon { color: #D94800; }
  .folio-link-body { flex: 1 1 0; min-width: 0; }
  .folio-link-title { font-family: 'Fraunces', serif; font-weight: 700; font-size: 0.95rem; color: #1A1A1A; }
  .folio-link-sub { font-size: 0.7rem; color: #6B5B4A; margin-top: 0.1rem; }
  .folio-link-arrow { font-size: 0.85rem; color: #6B5B4A; flex-shrink: 0; }

  /* BOM table */
  .bom-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
  }
  .bom-table th {
    text-align: left;
    padding: 0.6rem 0.75rem;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
