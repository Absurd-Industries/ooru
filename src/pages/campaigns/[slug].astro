<script is:inline data-astro-rerun>
// Load model-viewer only if a 3D model viewer is present on this page
if (document.querySelector('model-viewer')) {
  var script = document.createElement('script');
  script.type = 'module';
  script.src = 'https://ajax.googleapis.com/ajax/libs/model-viewer/4.0/model-viewer.min.js';
  document.head.appendChild(script);
}

// Share button - native share on mobile, clipboard fallback on desktop
document.querySelectorAll('.share-float-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    if (navigator.share) {
      navigator.share({ title: document.title, url: window.location.href }).catch(function() {});
    } else {
      navigator.clipboard.writeText(window.location.href).then(function() {
        var icon = btn.querySelector('i');
        icon.className = 'ph-bold ph-check';
        setTimeout(function() { icon.className = 'ph-bold ph-share-network'; }, 1500);
      });
    }
  });
});

// Show float pill after scrolling past hero
(function() {
  var pill = document.getElementById('campaign-float');
  if (!pill) return;
  pill.style.opacity = '0';
  pill.style.transform = 'translateY(20px)';
  pill.style.transition = 'opacity 0.3s, transform 0.3s';
  pill.style.pointerEvents = 'none';
  window.addEventListener('scroll', function() {
    if (window.scrollY > 300) {
      pill.style.opacity = '1';
      pill.style.transform = 'translateY(0)';
      pill.style.pointerEvents = 'auto';
    } else {
      pill.style.opacity = '0';
      pill.style.transform = 'translateY(20px)';
      pill.style.pointerEvents = 'none';
    }
  }, { passive: true });
})();

// Section nav scroll-spy (highlights the current section)
(function() {
  var nav = document.getElementById('section-nav');
  if (!nav) return;
  var links = Array.prototype.slice.call(nav.querySelectorAll('.section-nav-link'));
  if (!links.length) return;

  function setActive(id) {
    links.forEach(function(l) {
      l.classList.toggle('active', l.getAttribute('data-target') === id);
    });
  }

  var sections = links
    .map(function(l) { return document.getElementById(l.getAttribute('data-target')); })
    .filter(Boolean);

  var observer = new IntersectionObserver(function(entries) {
    var visible = entries.filter(function(e) { return e.isIntersecting; });
    if (!visible.length) return;
    visible.sort(function(a, b) { return a.boundingClientRect.top - b.boundingClientRect.top; });
    setActive(visible[0].target.id);
  }, { rootMargin: '-56px 0px -65% 0px', threshold: 0 });

  sections.forEach(function(s) { observer.observe(s); });
  links.forEach(function(l) {
    l.addEventListener('click', function() { setActive(l.getAttribute('data-target')); });
  });
})();
</script>
