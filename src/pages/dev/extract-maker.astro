---
import BaseLayout from "../../layouts/BaseLayout.astro";

// Dev-only. Fetches public pages server-side via /api/extract and derives a
// maker profile block. Public data only.
---

<BaseLayout title="Extract Maker" description="Dev tool" noindex={true} activeTab="">
  <div class="max-w-3xl mx-auto px-5 sm:px-6 pt-8 pb-24">
    <a href="/dev" class="inline-flex items-center gap-1.5 text-xs font-semibold text-stencil hover:text-stamp mb-5" style="text-decoration:none;">
      <i class="ph-bold ph-arrow-left"></i> Dev tools
    </a>

    <h1 class="font-serif font-black text-2xl sm:text-3xl text-ink mb-2">Extract Maker Profile</h1>
    <p class="text-ink-light text-sm leading-relaxed mb-6 max-w-lg">
      Paste a GitHub profile, personal website, or Shopify product URL. We fetch it server-side
      (no CORS proxy) and derive a paste-ready <code>makers.ts</code> block. Edit before committing.
    </p>

    <div class="space-y-3">
      <div class="flex flex-col sm:flex-row gap-2">
        <input
          id="url-input"
          type="url"
          placeholder="https://github.com/username  ·  https://maker.dev  ·  shop product URL"
          class="dev-input flex-1"
        />
        <button id="extract-btn" class="btn btn-stamp" style="white-space:nowrap;">
          <i class="ph-bold ph-magic-wand mr-1.5"></i>Extract
        </button>
      </div>
      <p class="text-xs text-stencil">
        Tip: a GitHub URL gives the richest result (name, bio, location, links, repo count).
      </p>
    </div>

    <div id="status" class="mt-4 text-sm hidden"></div>

    <div id="output" class="mt-6 hidden">
      <div class="flex items-center justify-between mb-2">
        <h2 class="font-serif font-bold text-base text-ink">makers.ts block</h2>
        <button id="copy-btn" class="btn btn-outline btn-sm">
          <i class="ph-bold ph-copy mr-1"></i>Copy
        </button>
      </div>
      <pre id="code-out" class="dev-pre"></pre>
    </div>
  </div>
</BaseLayout>

<style>
  .dev-input {
    border: 1.5px solid rgba(26,26,26,0.15);
    border-radius: 0.6rem;
    padding: 0.6rem 0.875rem;
    font-size: 0.875rem;
    background: rgba(250,243,232,0.6);
    color: #1A1A1A;
    transition: border-color 0.15s;
  }
  .dev-input:focus { outline: none; border-color: #D94800; }
  .dev-pre {
    background: #1A1A1A;
    color: #E8D5B7;
    border-radius: 0.6rem;
    padding: 1rem 1.25rem;
    font-size: 0.78rem;
    line-height: 1.6;
    overflow-x: auto;
    font-family: monospace;
    white-space: pre;
  }
</style>

<script is:inline>
(function () {
  const $ = (id) => document.getElementById(id);
  const statusEl = $("status");
  const outputEl = $("output");
  const codeOut = $("code-out");

  function setStatus(msg, kind) {
    statusEl.className = "mt-4 text-sm " + (kind === "error" ? "text-stamp" : "text-stencil");
    statusEl.textContent = msg;
    statusEl.classList.remove("hidden");
  }

  function slugify(s) {
    return String(s || "").toLowerCase().trim().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "");
  }

  function grab(html, re) { const m = html.match(re); return m ? m[1].trim() : ""; }

  function buildFromGitHub(html, username) {
    const name = grab(html, /<span[^>]*class="[^"]*vcard-fullname[^"]*"[^>]*>([^<]+)</) ||
                 grab(html, /<meta property="og:title" content="([^"]+)"/) || username;
    const bio = grab(html, /<div[^>]*class="[^"]*user-profile-bio[^"]*"[^>]*>([^<]+)</) ||
                grab(html, /<meta name="description" content="([^"]+)"/);
    const location = grab(html, /itemprop="homeLocation"[^>]*>\s*<span[^>]*>([^<]+)</) ||
                     grab(html, /<span class="p-label">([^<]+)</);
    const website = grab(html, /itemprop="url"[^>]*>\s*<a[^>]*href="([^"]+)"/);
    const cleanName = name.split("·")[0].trim();
    return {
      slug: slugify(username),
      name: cleanName,
      title: bio ? bio.slice(0, 60) : "Maker",
      location: location || "",
      avatarColor: "#1B6B5E",
      avatar: "/images/makers/" + slugify(username) + ".jpg",
      skills: ["Open Hardware"],
      projects: 1,
      backers: 0,
      specialty: "Hardware",
      bio: bio || "",
      links: { github: "https://github.com/" + username, website: website || undefined },
    };
  }

  function buildGeneric(html, url) {
    const title = grab(html, /<meta property="og:title" content="([^"]+)"/) || grab(html, /<title>([^<]+)</);
    const desc = grab(html, /<meta property="og:description" content="([^"]+)"/) ||
                 grab(html, /<meta name="description" content="([^"]+)"/);
    const name = title.split(/[|·\-–—]/)[0].trim();
    return {
      slug: slugify(name),
      name,
      title: "Maker",
      location: "",
      avatarColor: "#1B6B5E",
      avatar: "/images/makers/" + slugify(name) + ".jpg",
      skills: ["Open Hardware"],
      projects: 1,
      backers: 0,
      specialty: "Hardware",
      bio: desc || "",
      links: { website: url },
    };
  }

  function toMakerBlock(obj) {
    const lines = [];
    lines.push("{");
    lines.push('  slug: ' + JSON.stringify(obj.slug) + ',');
    lines.push('  name: ' + JSON.stringify(obj.name) + ',');
    lines.push('  title: ' + JSON.stringify(obj.title) + ',');
    lines.push('  location: ' + JSON.stringify(obj.location) + ',');
    lines.push('  avatarColor: ' + JSON.stringify(obj.avatarColor) + ',');
    lines.push('  avatar: ' + JSON.stringify(obj.avatar) + ',');
    lines.push('  skills: ' + JSON.stringify(obj.skills) + ',');
    lines.push('  projects: ' + obj.projects + ',');
    lines.push('  backers: ' + obj.backers + ',');
    lines.push('  specialty: ' + JSON.stringify(obj.specialty) + ',');
    lines.push('  bio: ' + JSON.stringify(obj.bio) + ',');
    const links = [];
    if (obj.links.github) links.push('github: ' + JSON.stringify(obj.links.github));
    if (obj.links.website) links.push('website: ' + JSON.stringify(obj.links.website));
    if (obj.links.twitter) links.push('twitter: ' + JSON.stringify(obj.links.twitter));
    lines.push('  links: { ' + links.join(", ") + ' },');
    lines.push("},");
    return lines.join("\n");
  }

  async function extract() {
    const url = $("url-input").value.trim();
    if (!url) { setStatus("Enter a URL first.", "error"); return; }
    setStatus("Fetching " + url + " ...");
    outputEl.classList.add("hidden");
    try {
      const res = await fetch("/api/extract", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ url }),
      });
      const data = await res.json();
      if (!res.ok || data.error) { setStatus(data.error || ("HTTP " + res.status), "error"); return; }
      const html = data.html || "";
      let obj;
      const gh = url.match(/github\.com\/([a-zA-Z0-9_-]+)\/?$/);
      if (gh) obj = buildFromGitHub(html, gh[1]);
      else obj = buildGeneric(html, data.finalUrl || url);
      codeOut.textContent = toMakerBlock(obj);
      outputEl.classList.remove("hidden");
      setStatus("Done. Review and edit the fields below before committing.");
    } catch (e) {
      setStatus("Failed: " + e.message, "error");
    }
  }

  $("extract-btn").addEventListener("click", extract);
  $("url-input").addEventListener("keydown", (e) => { if (e.key === "Enter") extract(); });
  $("copy-btn").addEventListener("click", () => {
    navigator.clipboard.writeText(codeOut.textContent).then(() => {
      const btn = $("copy-btn");
      btn.innerHTML = '<i class="ph-bold ph-check mr-1"></i>Copied';
      setTimeout(() => { btn.innerHTML = '<i class="ph-bold ph-copy mr-1"></i>Copy'; }, 1500);
    });
  });
})();
</script>
