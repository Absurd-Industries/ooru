---
/**
 * Experiment: an ambient "sea" of CoryDoras (the former CoryDora-page footer).
 * Lives under /dev so it can be iterated without loading on the live campaign page.
 */
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CoryDoraField from "../../../components/corydora/CoryDoraField.vue";
import { projects } from "../../../data/projects";
import { corydoraLanding as L } from "../../../data/corydora-landing";

const project = projects.find((p) => p.slug === L.projectSlug);
---

<BaseLayout
  title="Experiment · Sea of CoryDoras"
  description="Ambient instanced field of CoryDoras with generative OLED screens."
  noindex={true}
  activeTab=""
>
  <div class="exp-full">
    <a href="/dev" class="exp-back"><i class="ph-bold ph-arrow-left"></i> Dev</a>
    {
      project?.modelUrl ? (
        <CoryDoraField src={project.modelUrl} fill client:load />
      ) : (
        <p class="exp-missing">No CoryDora model found.</p>
      )
    }
  </div>
</BaseLayout>

<style>
  /* full-viewport overlay - covers the site chrome for an immersive experiment
     (BaseLayout still loads the fonts the generative screens need) */
  .exp-full { position: fixed; inset: 0; z-index: 9999; background: #12141a; }
  .exp-back {
    position: absolute; top: 12px; left: 12px; z-index: 10; display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.4rem 0.8rem; border-radius: 999px; font-size: 0.8rem; font-weight: 700; text-decoration: none;
    background: rgba(10, 10, 12, 0.6); color: #faf3e8; border: 1px solid rgba(255, 255, 255, 0.18); backdrop-filter: blur(8px);
  }
  .exp-back:hover { border-color: #ff6c1e; color: #ff9a5c; }
  .exp-missing { display: grid; place-items: center; height: 100%; color: #cbb89a; }
</style>
