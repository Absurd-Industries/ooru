---
import BaseLayout from "../../layouts/BaseLayout.astro";

// Dev-only. Previews scraped GitHub + Notion content for a project folio and
// emits the CLI command to run locally for asset download/conversion.
// Public data only.
---

<BaseLayout title="Build Folio" description="Dev tool" noindex={true} activeTab="">
  <div class="max-w-3xl mx-auto px-5 sm:px-6 pt-8 pb-24">
    <a href="/dev" class="inline-flex items-center gap-1.5 text-xs font-semibold text-stencil hover:text-stamp mb-5" style="text-decoration:none;">
      <i class="ph-bold ph-arrow-left"></i> Dev tools
    </a>

    <h1 class="font-serif font-black text-2xl sm:text-3xl text-ink mb-2">Build Project Folio</h1>
    <p class="text-ink-light text-sm leading-relaxed mb-6 max-w-lg">
      Scrapes a public GitHub repo (+ optional Notion pages) to preview folio content. The heavy
      asset work - image re-hosting, STEP to GLB - runs locally; this page gives you the exact
      command and a config template to drop into <code>tools/folio-builder/configs/</code>.
    </p>

    <div class="space-y-3">
      <div>
        <label class="dev-label">GitHub repo <span class="text-stamp">*</span></label>
        <input id="repo" type="text" placeholder="owner/repo  e.g. balub/CoryDora" class="dev-input w-full" />
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div>
          <label class="dev-label">Notion build guide ID</label>
          <input id="notion-build" type="text" placeholder="optional" class="dev-input w-full" />
        </div>
        <div>
          <label class="dev-label">Notion onboarding ID</label>
          <input id="notion-onboard" type="text" placeholder="optional" class="dev-input w-full" />
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div>
          <label class="dev-label">Shop URL</label>
          <input id="shop" type="url" placeholder="optional" class="dev-input w-full" />
        </div>
        <div>
          <label class="dev-label">PCB path (in repo)</label>
          <input id="pcb" type="text" placeholder="e.g. CoryDora.kicad_pcb" class="dev-input w-full" />
        </div>
      </div>
      <button id="scrape-btn" class="btn btn-stamp">
        <i class="ph-bold ph-magic-wand mr-1.5"></i>Scrape preview
      </button>
    </div>

    <div id="status" class="mt-4 text-sm hidden"></div>

    <div id="output" class="mt-6 hidden space-y-6">
      <div>
        <h2 class="font-serif font-bold text-base text-ink mb-2">Summary</h2>
        <div id="summary" class="dev-summary"></div>
      </div>

      <div>
        <div class="flex items-center justify-between mb-2">
          <h2 class="font-serif font-bold text-base text-ink">CLI command (run locally)</h2>
          <button class="btn btn-outline btn-sm copy-btn" data-target="cli-out">
            <i class="ph-bold ph-copy mr-1"></i>Copy
          </button>
        </div>
        <pre id="cli-out" class="dev-pre"></pre>
      </div>

      <div>
        <div class="flex items-center justify-between mb-2">
          <h2 class="font-serif font-bold text-base text-ink">config template</h2>
          <button class="btn btn-outline btn-sm copy-btn" data-target="config-out">
            <i class="ph-bold ph-copy mr-1"></i>Copy
          </button>
        </div>
        <pre id="config-out" class="dev-pre"></pre>
      </div>

      <details>
        <summary class="cursor-pointer font-serif font-bold text-base text-ink mb-2">Raw scrape (JSON)</summary>
        <pre id="raw-out" class="dev-pre mt-2" style="max-height: 400px;"></pre>
      </details>
    </div>
  </div>
</BaseLayout>

<style>
  .dev-label { display: block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: #6B5B4A; margin-bottom: 0.3rem; }
  .dev-input {
    border: 1.5px solid rgba(26,26,26,0.15);
    border-radius: 0.6rem;
    padding: 0.55rem 0.875rem;
    font-size: 0.85rem;
    background: rgba(250,243,232,0.6);
    color: #1A1A1A;
    transition: border-color 0.15s;
  }
  .dev-input:focus { outline: none; border-color: #D94800; }
  .dev-pre {
    background: #1A1A1A;
    color: #E8D5B7;
    border-radius: 0.6rem;
    padding: 1rem 1.25rem;
    font-size: 0.78rem;
    line-height: 1.6;
    overflow: auto;
    font-family: monospace;
    white-space: pre;
  }
  .dev-summary {
    background: rgba(250,243,232,0.6);
    border: 1px solid rgba(26,26,26,0.1);
    border-radius: 0.6rem;
    padding: 1rem 1.25rem;
    font-size: 0.85rem;
    line-height: 1.8;
  }
  .dev-summary .row { display: flex; justify-content: space-between; gap: 1rem; border-bottom: 1px solid rgba(26,26,26,0.06); padding: 0.2rem 0; }
  .dev-summary .row:last-child { border-bottom: none; }
  .dev-summary .k { color: #6B5B4A; font-size: 0.78rem; }
  .dev-summary .v { font-weight: 600; color: #1A1A1A; text-align: right; }
</style>

<script is:inline>
(function () {
  const $ = (id) => document.getElementById(id);
  const statusEl = $("status");
  const outputEl = $("output");

  function setStatus(msg, kind) {
    statusEl.className = "mt-4 text-sm " + (kind === "error" ? "text-stamp" : "text-stencil");
    statusEl.textContent = msg;
    statusEl.classList.remove("hidden");
  }

  function esc(s) { return String(s == null ? "" : s).replace(/&/g, "&amp;").replace(/</g, "&lt;"); }

  async function scrape() {
    const repo = $("repo").value.trim();
    if (!repo) { setStatus("GitHub repo is required.", "error"); return; }
    setStatus("Scraping " + repo + " ... (this can take a few seconds)");
    outputEl.classList.add("hidden");

    const body = { repo };
    const nb = $("notion-build").value.trim(); if (nb) body.notionBuildGuide = nb;
    const no = $("notion-onboard").value.trim(); if (no) body.notionOnboarding = no;
    const shop = $("shop").value.trim(); if (shop) body.shop = shop;
    const pcb = $("pcb").value.trim(); if (pcb) body.pcbPath = pcb;

    try {
      const res = await fetch("/api/scrape-folio", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });
      const data = await res.json();
      if (!res.ok || data.error) { setStatus(data.error || ("HTTP " + res.status), "error"); return; }

      // Summary
      const m = data.meta || {};
      const rows = [
        ["Repo", data.repo],
        ["Name", m.name],
        ["Description", m.description],
        ["License (reported)", m.license],
        ["Stars", m.stars],
        ["Source files", (data.files || []).length],
        ["Repo images", (data.imageFiles || []).length],
        ["Build-guide blocks", (data.buildGuide || []).length],
        ["Onboarding blocks", (data.onboarding || []).length],
        ["PCB viewer", data.pcbViewerUrl ? "yes" : "no"],
      ];
      $("summary").innerHTML = rows.map((r) =>
        '<div class="row"><span class="k">' + esc(r[0]) + '</span><span class="v">' + esc(r[1]) + '</span></div>'
      ).join("");

      $("cli-out").textContent = data.cliCommand || "";
      $("config-out").textContent = JSON.stringify(data.configTemplate || {}, null, 2);
      $("raw-out").textContent = JSON.stringify(data, null, 2);

      outputEl.classList.remove("hidden");
      setStatus("Done. Drop the config into tools/folio-builder/configs/ then run the CLI command locally.");
    } catch (e) {
      setStatus("Failed: " + e.message, "error");
    }
  }

  $("scrape-btn").addEventListener("click", scrape);
  document.querySelectorAll(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = document.getElementById(btn.getAttribute("data-target"));
      navigator.clipboard.writeText(target.textContent).then(() => {
        const orig = btn.innerHTML;
        btn.innerHTML = '<i class="ph-bold ph-check mr-1"></i>Copied';
        setTimeout(() => { btn.innerHTML = orig; }, 1500);
      });
    });
  });
})();
</script>
