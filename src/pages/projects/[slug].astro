---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/Card.astro";
import Tag from "../../components/Tag.astro";
import GalleryViewer from "../../components/GalleryViewer.vue";
import BomTable from "../../components/BomTable.vue";
import FilePreview from "../../components/FilePreview.vue";
import { projects } from "../../data/projects";
import { makers } from "../../data/makers";
import { campaigns } from "../../data/campaigns";
import type { Project } from "../../types";

export function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

interface Props { project: Project; }
const { project: p } = Astro.props;

const maker = makers.find((m) => m.slug === p.makerSlug);
const campaign = p.campaignSlug ? campaigns.find((c) => c.slug === p.campaignSlug) : null;

// Map source files to the FilePreview shape, inferring a preview type from the
// extension: code (text-fetch), csv (table), pdf (embed), else binary (download).
function fileType(name: string): "code" | "csv" | "pdf" | "binary" {
  const ext = name.toLowerCase().split(".").pop() || "";
  if (ext === "pdf") return "pdf";
  if (ext === "csv") return "csv";
  if (["kicad_pcb", "kicad_sch", "kicad_sym", "txt", "md", "json", "scad"].includes(ext))
    return "code";
  return "binary";
}
const previewFiles = (p.files ?? []).map((f) => ({
  name: f.name,
  format: f.format,
  icon: f.icon,
  type: fileType(f.name),
  filename: f.name,
  url: f.url,
  meta: f.format,
}));

const statusLabel = p.status === "shipping" ? "Shipping now" : p.status === "prototype" ? "Prototype" : "Concept";
const statusVariant = p.status === "shipping" ? "funded" : "default";

const sectionNav = [
  p.specs?.length ? { id: "specs", label: "Specs" } : null,
  p.modelUrl ? { id: "model", label: "3D Model" } : null,
  p.pcbViewerUrl ? { id: "pcb", label: "PCB" } : null,
  p.bom?.length ? { id: "bom", label: "BOM" } : null,
  p.files?.length ? { id: "files", label: "Files" } : null,
  p.buildGuide ? { id: "build", label: "Build Guide" } : null,
  p.onboarding ? { id: "onboarding", label: "Onboarding" } : null,
  p.faqs?.length ? { id: "faq", label: "FAQ" } : null,
].filter(Boolean) as { id: string; label: string }[];

const projectLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: p.title,
  description: p.tagline,
  category: p.category,
  url: new URL(`/projects/${p.slug}`, Astro.site).href,
  ...(p.shopUrl ? { offers: { "@type": "Offer", url: p.shopUrl } } : {}),
};
---

<BaseLayout
  title={p.title}
  description={p.tagline}
  ogImage={`/og/campaigns/${p.campaignSlug ?? p.slug}.jpg`}
  ogType="article"
  jsonLd={projectLd}
  activeTab="campaigns"
  hideNav
>
  <!-- ── Hero ────────────────────────────────────────────────────────── -->
  <div class:list={["folio-hero", p.heroImages.length <= 1 && "folio-hero--single"]}>
    {p.heroImages.length > 1 ? (
      <GalleryViewer images={p.heroImages} alt={p.title} variant="hero" client:load />
    ) : p.heroImages[0] ? (
      <img src={p.heroImages[0]} alt={p.title} class="w-full h-full object-cover" />
    ) : null}
    <a href="/projects" class="hero-overlay-btn hero-overlay-btn--back" title="Back to projects">
      <i class="ph-bold ph-arrow-left"></i>
    </a>
    <button class="hero-overlay-btn hero-overlay-btn--share share-btn" title="Copy link">
      <i class="ph-bold ph-share-network"></i>
    </button>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-6 sm:pt-8 pb-24">
    <div class="flex flex-col lg:flex-row gap-6 items-start">

      <!-- ── Main column ────────────────────────────────────────────── -->
      <div class="flex-1 min-w-0">

        <Card>

          <!-- Title block -->
          <div class="folio-section">
            <div class="flex items-start gap-4">
              <div class="flex-1 min-w-0">
                <h1 class="font-serif text-2xl sm:text-3xl md:text-4xl font-black tracking-tight leading-tight mb-3">
                  {p.title}
                </h1>
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <Tag variant={statusVariant}>{statusLabel}</Tag>
                  <Tag>{p.category}</Tag>
                  <Tag>
                    <i class="ph-bold ph-scales mr-1" style="font-size:0.65rem;"></i>
                    {p.license}
                  </Tag>
                </div>
                <p class="text-base text-ink-light leading-relaxed">{p.tagline}</p>
              </div>
            </div>

            <!-- External action links -->
            <div class="flex flex-wrap gap-2 mt-4">
              {p.shopUrl && (
                <a href={p.shopUrl} target="_blank" rel="noopener" class="btn btn-stamp btn-sm" style="text-decoration:none;">
                  <i class="ph-bold ph-storefront mr-1.5"></i>
                  Buy {p.priceFormatted ?? "now"}
                </a>
              )}
              {p.repoUrl && (
                <a href={p.repoUrl} target="_blank" rel="noopener" class="btn btn-outline btn-sm" style="text-decoration:none;">
                  <i class="fab fa-github mr-1.5"></i>
                  GitHub
                </a>
              )}
              {p.firmwareUrl && (
                <a href={p.firmwareUrl} target="_blank" rel="noopener" class="btn btn-outline btn-sm" style="text-decoration:none;">
                  <i class="ph-bold ph-terminal-window mr-1.5"></i>
                  Firmware
                </a>
              )}
            </div>
          </div>

          <!-- Sticky section nav -->
          <nav class="section-nav" id="section-nav">
            {sectionNav.map((s) => (
              <a href={`#sec-${s.id}`} class="section-nav-link" data-target={`sec-${s.id}`}>
                {s.label}
              </a>
            ))}
          </nav>

          <!-- ── Specs strip ──────────────────────────────────────── -->
          {p.specs?.length && (
            <div class="folio-section" id="sec-specs">
              <h2 class="folio-h2">
                <i class="ph-duotone ph-list-numbers"></i>
                Specifications
              </h2>
              <div class="spec-grid">
                {p.specs.map((s) => (
                  <div class="spec-cell">
                    <div class="spec-label">{s.label}</div>
                    <div class="spec-value">{s.value}</div>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- ── Features ─────────────────────────────────────────── -->
          {p.features?.length && (
            <div class="folio-section">
              <h2 class="folio-h2">
                <i class="ph-duotone ph-star"></i>
                Features
              </h2>
              <ul class="feature-list">
                {p.features.map((f) => (
                  <li class="feature-item">
                    <i class="ph-bold ph-check-circle text-funded flex-shrink-0"></i>
                    <span class="text-sm">{f}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- ── 3D Model ─────────────────────────────────────────── -->
          {p.modelUrl && (
            <div class="folio-section" id="sec-model">
              <h2 class="folio-h2">
                <i class="ph-duotone ph-cube"></i>
                3D Model
              </h2>
              <div class="viewer-frame" style="height: 420px;">
                <model-viewer
                  src={p.modelUrl}
                  alt={`${p.title} 3D model`}
                  camera-controls
                  auto-rotate
                  shadow-intensity="0.6"
                  environment-image="neutral"
                  exposure="1.15"
                  camera-orbit="35deg 65deg auto"
                  style="width: 100%; height: 100%;"
                ></model-viewer>
              </div>
              <p class="text-xs text-stencil mt-2">Drag to rotate - scroll to zoom - pinch on mobile</p>
            </div>
          )}

          <!-- ── PCB Viewer ───────────────────────────────────────── -->
          {p.pcbViewerUrl && (
            <div class="folio-section" id="sec-pcb">
              <h2 class="folio-h2">
                <i class="ph-duotone ph-circuit-board"></i>
                PCB Design
              </h2>
              <div class="viewer-frame" style="height: 400px; border: 1px solid rgba(26,26,26,0.08);">
                <iframe
                  src={p.pcbViewerUrl}
                  title={`${p.title} PCB`}
                  class="w-full h-full"
                  style="border: none;"
                ></iframe>
              </div>
              <p class="text-xs text-stencil mt-2">
                Powered by <a href="https://kicanvas.org" target="_blank" rel="noopener" class="hover:text-stamp" style="text-decoration:none;">KiCanvas</a>
              </p>
            </div>
          )}

          <!-- ── BOM ─────────────────────────────────────────────── -->
          {p.bom?.length && (
            <div class="folio-section" id="sec-bom">
              <div class="flex items-center justify-between mb-4">
                <h2 class="folio-h2 mb-0">
                  <i class="ph-duotone ph-list-checks"></i>
                  Bill of Materials
                </h2>
                <Tag>{p.bom.length} parts</Tag>
              </div>
              <BomTable items={p.bom} client:visible />
            </div>
          )}

          <!-- ── Files ───────────────────────────────────────────── -->
          {p.files?.length && (
            <div class="folio-section" id="sec-files">
              <h2 class="folio-h2">
                <i class="ph-duotone ph-folder-open"></i>
                Source Files
              </h2>
              <p class="text-xs text-stencil mb-4">Click any file to preview it - read the schematic, scan the BOM, then download.</p>
              <FilePreview files={previewFiles} campaignSlug={p.slug} license={p.license} client:visible />
            </div>
          )}

          <!-- ── Build Guide ─────────────────────────────────────── -->
          {p.buildGuide && (
            <div class="folio-section" id="sec-build">
              <h2 class="folio-h2">
                <i class="ph-duotone ph-wrench"></i>
                Build Guide
              </h2>
              {p.buildGuide.intro && (
                <p class="text-sm text-ink-light leading-relaxed mb-6">{p.buildGuide.intro}</p>
              )}
              <div class="guide-steps">
                {p.buildGuide.steps.map((step, idx) => (
                  <div class="guide-step">
                    <div class="guide-step-num">{idx + 1}</div>
                    <div class="guide-step-content">
                      <h3 class="guide-step-title">{step.title}</h3>
                      {step.body && (
                        <p class="guide-step-body">{step.body}</p>
                      )}
                      {step.note && (
                        <div class="guide-note">
                          <i class="ph-bold ph-warning-circle"></i>
                          {step.note}
                        </div>
                      )}
                      {step.images?.length && (
                        <div class:list={["guide-images", step.images.length === 1 && "guide-images--single"]}>
                          {step.images.map((img, i) => (
                            <img
                              src={img}
                              alt={`${step.title} - step ${i + 1}`}
                              class="guide-img"
                              loading="lazy"
                            />
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- ── Onboarding ──────────────────────────────────────── -->
          {p.onboarding && (
            <div class="folio-section" id="sec-onboarding">
              <h2 class="folio-h2">
                <i class="ph-duotone ph-rocket-launch"></i>
                Getting Started
              </h2>
              {p.onboarding.intro && (
                <p class="text-sm text-ink-light leading-relaxed mb-6">{p.onboarding.intro}</p>
              )}
              <div class="guide-steps">
                {p.onboarding.steps.map((step, idx) => (
                  <div class="guide-step">
                    <div class="guide-step-num">{idx + 1}</div>
                    <div class="guide-step-content">
                      <h3 class="guide-step-title">{step.title}</h3>
                      {step.body && (
                        <p class="guide-step-body">{step.body}</p>
                      )}
                      {step.note && (
                        <div class="guide-note">
                          <i class="ph-bold ph-warning-circle"></i>
                          {step.note}
                        </div>
                      )}
                      {step.images?.length && (
                        <div class:list={["guide-images", step.images.length === 1 && "guide-images--single"]}>
                          {step.images.map((img, i) => (
                            <img
                              src={img}
                              alt={`${step.title} - step ${i + 1}`}
                              class="guide-img"
                              loading="lazy"
                            />
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- ── FAQ ────────────────────────────────────────────── -->
          {p.faqs?.length && (
            <div class="folio-section" id="sec-faq">
              <h2 class="folio-h2">
                <i class="ph-duotone ph-question"></i>
                FAQ
              </h2>
              <div class="campaign-faq">
                {p.faqs.map((f) => (
                  <details class="campaign-faq-item" name="project-faq">
                    <summary class="campaign-faq-q">
                      <span>{f.q}</span>
                      <i class="ph-bold ph-caret-down campaign-faq-caret"></i>
                    </summary>
                    <div class="campaign-faq-a">{f.a}</div>
                  </details>
                ))}
              </div>
            </div>
          )}

        </Card>

      </div>

      <!-- ── Sidebar ───────────────────────────────────────────────── -->
      <div class="w-full lg:w-72 flex-shrink-0 space-y-5">

        <!-- Buy / status card -->
        <Card>
          <div class="p-5">
            <div class="flex items-center gap-2 mb-4">
              <Tag variant={statusVariant}>{statusLabel}</Tag>
              {p.priceFormatted && (
                <span class="font-serif font-black text-2xl text-ink ml-auto">{p.priceFormatted}</span>
              )}
            </div>
            {p.shopUrl && (
              <a href={p.shopUrl} target="_blank" rel="noopener" class="btn btn-stamp w-full mb-2" style="text-decoration:none;">
                <i class="ph-bold ph-storefront mr-2"></i>Buy on shop
              </a>
            )}
            {p.repoUrl && (
              <a href={p.repoUrl} target="_blank" rel="noopener" class="btn btn-outline w-full btn-sm" style="text-decoration:none;">
                <i class="fab fa-github mr-2"></i>View source
              </a>
            )}
            {campaign && (
              <a href={`/campaigns/${campaign.slug}`} class="btn btn-outline w-full btn-sm mt-2" style="text-decoration:none;">
                <i class="ph-bold ph-rocket-launch mr-2"></i>Campaign page
              </a>
            )}
          </div>
        </Card>

        <!-- Maker card (matches the campaign page creator card) -->
        {maker && (
          <Card>
            <div class="p-5">
              <div class="text-[0.6rem] font-bold uppercase tracking-wider text-ink-faint mb-3">Made by</div>
              <div class="flex items-center gap-3 mb-4">
                {maker.avatar ? (
                  <img
                    src={maker.avatar}
                    alt={maker.name}
                    class="w-12 h-12 object-cover flex-shrink-0 oct-sm"
                  />
                ) : (
                  <div
                    class="w-12 h-12 flex items-center justify-center text-sm font-bold text-paper flex-shrink-0 oct-sm"
                    style={`background: ${maker.avatarColor}`}
                  >
                    {maker.name.split(" ").map((w) => w[0]).join("")}
                  </div>
                )}
                <div class="min-w-0">
                  <div class="font-semibold text-sm leading-tight">{maker.name}</div>
                  <div class="text-xs text-ink-faint flex items-center gap-1">
                    <i class="ph-bold ph-map-pin" style="font-size:0.7rem;"></i>{maker.location}
                  </div>
                </div>
              </div>

              <div class="creator-stats">
                <div>
                  <div class="creator-stat-num">{maker.projects}</div>
                  <div class="creator-stat-label">{maker.projects === 1 ? "project" : "projects"}</div>
                </div>
                <div>
                  <div class="creator-stat-num">{maker.backers}</div>
                  <div class="creator-stat-label">backers</div>
                </div>
              </div>

              {maker.bio && (
                <p class="text-xs text-ink-light leading-relaxed mt-3 mb-4">{maker.bio}</p>
              )}

              <div class="grid grid-cols-2 gap-2">
                <a href={`/makers/${maker.slug}`} class="btn btn-outline btn-sm w-full" style="text-decoration:none;">Profile</a>
                {maker.links?.github ? (
                  <a href={maker.links.github} target="_blank" rel="noopener" class="btn btn-outline btn-sm w-full" style="text-decoration:none;">
                    <i class="fab fa-github mr-1"></i>GitHub
                  </a>
                ) : maker.links?.website ? (
                  <a href={maker.links.website} target="_blank" rel="noopener" class="btn btn-outline btn-sm w-full" style="text-decoration:none;">
                    <i class="ph-bold ph-globe mr-1"></i>Site
                  </a>
                ) : (
                  <a href="/makers" class="btn btn-outline btn-sm w-full" style="text-decoration:none;">Makers</a>
                )}
              </div>
            </div>
          </Card>
        )}

        <!-- Quick spec strip (sidebar) -->
        {p.specs?.length && (
          <Card>
            <div class="p-5">
              <div class="text-[0.6rem] font-bold uppercase tracking-wider text-stencil mb-3">Quick specs</div>
              <dl class="space-y-2">
                {p.specs.slice(0, 6).map((s) => (
                  <div class="flex items-start justify-between gap-2">
                    <dt class="text-xs text-stencil flex-shrink-0">{s.label}</dt>
                    <dd class="text-xs font-semibold text-ink text-right">{s.value}</dd>
                  </div>
                ))}
              </dl>
            </div>
          </Card>
        )}

      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* ── Hero ────────────────────────────────────────────────────────── */
  /* Multi-image: height comes from the GalleryViewer (hero variant). */
  .folio-hero {
    position: relative;
    width: 100%;
    background: #E8D5B7;
  }
  /* Single image: fixed cover height. */
  .folio-hero--single {
    height: 280px;
    overflow: hidden;
  }
  @media (min-width: 640px) { .folio-hero--single { height: 360px; } }
  @media (min-width: 1024px) { .folio-hero--single { height: 460px; } }
  .folio-hero--single img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* hero overlay buttons (identical to campaign page) */
  .hero-overlay-btn {
    position: absolute;
    z-index: 10;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(26, 26, 26, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: #FAF3E8;
    border: 1.5px solid rgba(250, 243, 232, 0.15);
    cursor: pointer;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    text-decoration: none;
  }
  .hero-overlay-btn:hover {
    background: rgba(26, 26, 26, 0.8);
    border-color: rgba(250, 243, 232, 0.3);
  }
  .hero-overlay-btn--back { top: 12px; left: 12px; }
  .hero-overlay-btn--share { top: 12px; right: 12px; }

  /* ── Folio sections ──────────────────────────────────────────────── */
  .folio-section {
    padding: 1.25rem 1.5rem;
    border-top: 1px solid rgba(26, 26, 26, 0.06);
  }
  .folio-section:first-child { border-top: none; }
  @media (min-width: 640px) { .folio-section { padding: 1.75rem 2rem; } }

  .folio-h2 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Fraunces', serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: #1A1A1A;
    margin-bottom: 1rem;
  }
  .folio-h2 i { font-size: 1rem; color: #6B5B4A; }
  .folio-h2.mb-0 { margin-bottom: 0; }

  /* ── Sticky section nav (reused from campaign page) ─────────────── */
  .section-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    gap: 0.25rem;
    overflow-x: auto;
    scrollbar-width: none;
    background: rgba(250, 243, 232, 0.9);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-top: 1px solid rgba(26, 26, 26, 0.06);
    border-bottom: 1px solid rgba(26, 26, 26, 0.08);
    padding: 0.4rem 1rem;
  }
  .section-nav::-webkit-scrollbar { display: none; }
  @media (min-width: 640px) { .section-nav { padding: 0.45rem 2rem; } }
  .section-nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    color: #6B5B4A;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s, background 0.15s;
  }
  .section-nav-link:hover { color: #1A1A1A; }
  .section-nav-link.active { color: #1A1A1A; background: rgba(26, 26, 26, 0.06); }
  [id^="sec-"] { scroll-margin-top: 56px; }

  /* ── Spec grid ──────────────────────────────────────────────────── */
  .spec-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.625rem;
  }
  .spec-cell {
    background: rgba(212, 184, 150, 0.15);
    border-radius: 0.5rem;
    padding: 0.6rem 0.75rem;
    border: 1px solid rgba(26, 26, 26, 0.05);
  }
  .spec-label { font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: #6B5B4A; margin-bottom: 0.25rem; }
  .spec-value { font-size: 0.85rem; font-weight: 600; color: #1A1A1A; }

  /* ── Feature list ───────────────────────────────────────────────── */
  .feature-list { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .feature-item { display: flex; align-items: flex-start; gap: 0.6rem; font-size: 0.9rem; line-height: 1.5; }
  .feature-item i { font-size: 0.9rem; margin-top: 0.1rem; }

  /* ── Viewer frame ───────────────────────────────────────────────── */
  .viewer-frame {
    border-radius: 0.75rem;
    overflow: hidden;
    background: #F0EAE0;
  }

  /* ── Build guide stepper ────────────────────────────────────────── */
  .guide-steps { display: flex; flex-direction: column; gap: 0; }
  .guide-step {
    display: flex;
    gap: 1rem;
    position: relative;
    padding-bottom: 1.75rem;
  }
  .guide-step:last-child { padding-bottom: 0; }
  .guide-step::before {
    content: '';
    position: absolute;
    left: 15px;
    top: 36px;
    bottom: 0;
    width: 2px;
    background: rgba(26, 26, 26, 0.08);
  }
  .guide-step:last-child::before { display: none; }
  .guide-step-num {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #1A1A1A;
    color: #FAF3E8;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Fraunces', serif;
    font-weight: 700;
    font-size: 0.8rem;
    position: relative;
    z-index: 1;
  }
  .guide-step-content { flex: 1 1 0; min-width: 0; padding-top: 0.3rem; }
  .guide-step-title {
